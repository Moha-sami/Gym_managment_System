@using GymMangment.BLL.ViewModels.PlansViewModels
@model PlanViewModel
@{
    ViewData["Title"] = "Package Details";
}

<style>
    .plan-details-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 24px 16px;
        color: #ffffff;
    }
    .plan-card-glass {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border-radius: 28px;
        box-shadow: 0 24px 60px rgba(0,0,0,0.5);
        overflow: hidden;
        padding: 40px 32px;
    }
    .price-badge-glow {
        background: rgba(0, 240, 255, 0.1);
        border: 1px solid rgba(0, 240, 255, 0.25);
        border-radius: 20px;
        padding: 24px;
        text-align: center;
        margin-bottom: 28px;
    }
    .info-tile {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 18px;
        padding: 16px 20px;
        margin-bottom: 16px;
    }
    .tile-label {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        color: rgba(255, 255, 255, 0.4);
        margin-bottom: 4px;
        display: block;
    }
</style>

<div class="plan-details-container my-4">
    <div class="plan-card-glass">
        <!-- Header -->
        <div class="text-center mb-4 pb-3 border-bottom border-white-10">
            <div class="mx-auto mb-3 d-inline-flex align-items-center justify-content-center rounded-circle" style="width:64px;height:64px;background:linear-gradient(135deg,#7c3aed,#db2777);box-shadow:0 8px 24px rgba(124,58,237,0.35);">
                <i class="bi bi-award fs-2 text-white"></i>
            </div>
            <h2 class="fw-bold text-white mb-1">@Model.Name Package</h2>
            <span class="badge rounded-pill px-3 py-1.5 fs-6 mt-1" style="@(Model.IsActive ? "background:rgba(34,197,94,0.15);border:1px solid rgba(34,197,94,0.3);color:#4ade80;" : "background:rgba(248,113,113,0.15);border:1px solid rgba(248,113,113,0.3);color:#f87171;")">
                <i class="bi @(Model.IsActive ? "bi-check-circle-fill me-1" : "bi-x-circle-fill me-1")"></i>
                @(Model.IsActive ? "Active Package" : "Inactive Package")
            </span>
        </div>

        <!-- Price Callout -->
        <div class="price-badge-glow">
            <div class="display-3 fw-extrabold text-neon">@Model.Price <span class="fs-5 text-white-50">EGP</span></div>
            <p class="text-white-50 small mb-0 mt-1">Full access package price per renewal cycle.</p>
        </div>

        <!-- Details -->
        <div class="info-tile">
            <span class="tile-label"><i class="bi bi-calendar-check me-1"></i> Validity Duration</span>
            <div class="fs-5 fw-bold text-white">@Model.DurationInDays <small class="fs-6 text-white-50">Days</small></div>
        </div>

        <div class="info-tile">
            <span class="tile-label"><i class="bi bi-file-text me-1"></i> Package Coverage & Perks</span>
            <p class="text-white-50 small mb-0" style="line-height:1.5;">@Model.Description</p>
        </div>

        <!-- Action Bar -->
        <div class="d-flex justify-content-center gap-3 mt-4 pt-3 border-top border-white-10 action-bar-wrap">
            <a asp-controller="Plans" asp-action="Index" class="btn btn-glow-pill rounded-pill py-2.5 px-4 justify-content-center">
                <i class="bi bi-arrow-left"></i> Back to Packages
            </a>
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Plans" asp-action="EditPlan" asp-route-id="@Model.Id" class="btn btn-neon rounded-pill py-2.5 px-4 justify-content-center">
                    <i class="bi bi-pencil me-1"></i> Edit Specs
                </a>
            }
        </div>
    </div>
</div>
