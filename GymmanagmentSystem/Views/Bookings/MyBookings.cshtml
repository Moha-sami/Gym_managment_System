@using GymMangment.BLL.ViewModels.BookingViewModels
@model IEnumerable<BookingViewModel>
@{
    ViewData["Title"] = "My Bookings";
}

<div class="container">
    <header class="d-flex justify-content-between mt-5 mb-4 align-items-center">
        <div>
            <h2 class="text-primary-color mb-0">My Bookings</h2>
            <p class="text-muted">Your session bookings</p>
        </div>
        <a asp-controller="SessionsSchedule" asp-action="Index" class="btn btn-fill fw-medium rounded-pill px-4 py-3">
            <i class="bi bi-calendar-plus me-2"></i>Book a Session
        </a>
    </header>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-borderless">
                <thead>
                    <tr>
                        <th><span>Session</span></th>
                        <th><span>Date</span></th>
                        <th><span>Time</span></th>
                        <th><span>Booking Date</span></th>
                        <th><span>Attended</span></th>
                        <th><span>Action</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model)
                    {
                        <tr>
                            <td><span class="fw-bold">@booking.SessionCategory</span></td>
                            <td><span>@booking.SessionDate</span></td>
                            <td><span>@booking.SessionTime</span></td>
                            <td><span>@booking.BookingDate.ToString("MMM dd, yyyy")</span></td>
                            <td>
                                @if (booking.IsAttended)
                                {
                                    <span class="badge bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td>
                                <a asp-controller="Bookings" asp-action="Delete" asp-route-id="@booking.Id"
                                   class="btn btn-outline text-danger btn-sm">
                                    <i class="bi bi-trash me-1"></i>Cancel
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No Bookings Yet</h4>
            <p class="text-muted">Book your first session to get started</p>
        </div>
    }
</div>