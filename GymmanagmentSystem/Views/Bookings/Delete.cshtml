@using GymMangment.BLL.ViewModels.BookingViewModels
@model BookingViewModel
@{
    ViewData["Title"] = "Cancel Booking";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card p-5 shadow text-center">
                <p class="fs-3 text-primary-color mb-4">
                    Cancel <strong>@Model.MemberName</strong>'s booking for <strong>@Model.SessionCategory</strong>?
                </p>
                <div class="alert alert-warning text-start" role="alert">
                    <strong>Warning!</strong> This action cannot be undone. The booking will be permanently cancelled.
                </div>
                <div class="mb-3 text-muted">
                    <p class="mb-1"><i class="bi bi-calendar3 me-2"></i>@Model.SessionDate</p>
                    <p class="mb-1"><i class="bi bi-clock me-2"></i>@Model.SessionTime</p>
                </div>

                <form asp-controller="Bookings"
                      asp-action="DeleteConfirmed"
                      asp-route-memberId="@Model.MemberId"
                      asp-route-sessionId="@Model.SessionId"
                      method="post" class="mt-4">

                    <div class="buttons d-flex justify-content-between gap-3">
                        <a asp-controller="Bookings" asp-action="Index" class="btn-outline flex-fill">NO</a>
                        <button type="submit" class="btn-fill flex-fill">Yes, Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>