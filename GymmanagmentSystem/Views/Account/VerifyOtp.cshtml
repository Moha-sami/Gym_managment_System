@using GymMangment.BLL.ViewModels.AccountViewModels
@model VerifyOtpViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify OTP - Power Fitness</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="icon" type="image/png" href="~/my-gym-icon.png?v=3" />
    <style>
        :root {
            --primary-blue: #0a1172;
            --secondary-blue: #1a2396;
            --accent-blue: #2d3fdb;
            --text-dark: #2c3e50;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .auth-container {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            max-width: 450px;
            width: 100%;
            padding: 40px 35px;
        }

        .logo-icon {
            width: 70px;
            height: 70px;
            background: var(--primary-blue);
            border-radius: 15px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            box-shadow: 0 4px 15px rgba(10, 17, 114, 0.3);
        }

        .logo-icon i {
            font-size: 35px;
            color: white;
        }

        .auth-title {
            font-size: 26px;
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 10px;
        }

        .auth-subtitle {
            color: #6c757d;
            margin-bottom: 30px;
            font-size: 14px;
        }

        .form-floating {
            margin-bottom: 20px;
        }

        .form-control {
            border: 2px solid #e9ecef;
            border-radius: 10px;
            padding: 12px 20px;
            font-size: 15px;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            border-color: var(--primary-blue);
            box-shadow: 0 0 0 0.2rem rgba(10, 17, 114, 0.1);
        }

        .btn-auth {
            background: var(--primary-blue);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 14px;
            font-size: 16px;
            font-weight: 600;
            width: 100%;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 10px;
        }

        .btn-auth:hover {
            background: var(--secondary-blue);
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(10, 17, 114, 0.4);
        }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 25px;
            color: var(--primary-blue);
            text-decoration: none;
            font-weight: 600;
            font-size: 15px;
            transition: 0.3s;
        }

        .back-link:hover {
            color: var(--accent-blue);
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="text-center">
            <div class="logo-icon">
                <i class="bi bi-shield-check"></i>
            </div>
            <h2 class="auth-title">Verify OTP</h2>
            <p class="auth-subtitle">We have sent a 6-digit OTP code to <strong>@Model.Email</strong>. Enter it below to verify.</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success text-center py-2 mb-3" style="font-size: 0.9rem;">
                @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger text-center py-2 mb-3" style="font-size: 0.9rem;">
                @TempData["ErrorMessage"]
            </div>
        }

        <form asp-controller="Account" asp-action="VerifyOtp" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
            <input type="hidden" asp-for="Email" />

            <div class="form-floating">
                <input asp-for="Otp" class="form-control text-center fw-bold fs-4" placeholder="123456" required autocomplete="off" maxlength="6" autofocus style="letter-spacing: 8px;" />
                <label asp-for="Otp">Enter 6-Digit OTP</label>
                <span asp-validation-for="Otp" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-auth">Verify Code</button>
        </form>

        <a asp-controller="Account" asp-action="ForgotPassword" class="back-link">
            <i class="bi bi-arrow-left me-2"></i>Change Email
        </a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
