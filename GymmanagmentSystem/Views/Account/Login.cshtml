@using GymMangment.BLL.ViewModels.AccountViewModels
@model LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login – Power Fitness</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="~/my-gym-icon.png?v=3" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --accent:   #00f0ff;
            --purple:   #7c3aed;
            --pink:     #db2777;
            --bg:       #07060f;
            --glass-bg: rgba(255,255,255,0.04);
            --glass-border: rgba(255,255,255,0.09);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            min-height: 100vh;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* ─── Animated background ─── */
        .bg-scene {
            position: fixed;
            inset: 0;
            z-index: 0;
            overflow: hidden;
        }

        .bg-image {
            position: absolute;
            inset: 0;
            background: url('/images/workout1_gym.jpg') center/cover no-repeat;
            filter: brightness(0.18) saturate(1.4);
        }

        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(130px);
            opacity: 0.5;
            animation: drift 20s infinite alternate ease-in-out;
        }
        .orb-1 { width: 600px; height: 600px; background: radial-gradient(circle, var(--purple), transparent 70%); top: -200px; left: -200px; }
        .orb-2 { width: 500px; height: 500px; background: radial-gradient(circle, var(--pink), transparent 70%); bottom: -150px; right: -150px; animation-delay: -8s; }
        .orb-3 { width: 400px; height: 400px; background: radial-gradient(circle, #0ea5e9, transparent 70%); top: 40%; right: 10%; animation-delay: -14s; }

        @@keyframes drift {
            0%   { transform: translate(0,0) scale(1); }
            50%  { transform: translate(40px,-60px) scale(1.1); }
            100% { transform: translate(-30px,30px) scale(0.95); }
        }

        /* ─── Layout ─── */
        .page-wrap {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 1100px;
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
            align-items: center;
            padding: 40px 24px;
            gap: 48px;
        }

        /* ─── LEFT – branding panel ─── */
        .brand-panel {
            color: #fff;
            padding: 24px 0;
            animation: fadeUp 0.7s ease both;
        }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(28px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .logo-pill {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            backdrop-filter: blur(12px);
            border-radius: 50px;
            padding: 10px 20px;
            margin-bottom: 36px;
        }
        .logo-pill i { font-size: 22px; color: var(--accent); }
        .logo-pill span { font-size: 14px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; }

        .brand-headline {
            font-size: clamp(2.4rem, 4.5vw, 3.5rem);
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 20px;
            letter-spacing: -1px;
        }
        .brand-headline .grad {
            background: linear-gradient(135deg, var(--accent) 0%, var(--purple) 50%, var(--pink) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .brand-sub {
            color: rgba(255,255,255,0.55);
            font-size: 1.05rem;
            line-height: 1.7;
            max-width: 400px;
            margin-bottom: 40px;
        }

        /* stat chips */
        .stat-chips {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
            margin-top: 36px;
        }
        .chip {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            backdrop-filter: blur(10px);
            border-radius: 16px;
            padding: 14px 22px;
            text-align: center;
            flex: 1;
            min-width: 90px;
        }
        .chip-num {
            font-size: 1.6rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--accent), var(--purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            display: block;
            line-height: 1.1;
        }
        .chip-label {
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: rgba(255,255,255,0.45);
            margin-top: 4px;
            display: block;
        }

        /* feature list */
        .feature-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-top: 32px;
        }
        .feature-list li {
            display: flex;
            align-items: center;
            gap: 12px;
            color: rgba(255,255,255,0.7);
            font-size: 0.9rem;
        }
        .feature-list li i {
            width: 28px;
            height: 28px;
            border-radius: 8px;
            background: linear-gradient(135deg, var(--purple), var(--pink));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
            color: #fff;
        }

        /* ─── RIGHT – form card ─── */
        .form-card {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            backdrop-filter: blur(28px) saturate(180%);
            -webkit-backdrop-filter: blur(28px) saturate(180%);
            border-radius: 28px;
            padding: 48px 44px;
            box-shadow: 0 32px 80px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.08);
            animation: fadeUp 0.7s 0.15s ease both;
        }

        .form-header {
            text-align: center;
            margin-bottom: 36px;
        }
        .form-header h2 {
            font-size: 1.75rem;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.5px;
            margin-bottom: 6px;
        }
        .form-header p {
            color: rgba(255,255,255,0.45);
            font-size: 0.875rem;
        }

        /* avatar icon row */
        .auth-icon {
            width: 60px;
            height: 60px;
            border-radius: 18px;
            background: linear-gradient(135deg, var(--purple), var(--pink));
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 18px;
            box-shadow: 0 8px 24px rgba(124,58,237,0.4);
        }
        .auth-icon i { font-size: 28px; color: #fff; }

        /* inputs */
        .field-wrap {
            position: relative;
            margin-bottom: 16px;
        }
        .field-wrap i.field-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,0.35);
            font-size: 16px;
            pointer-events: none;
            transition: color 0.3s;
        }
        .field-wrap input:focus + .field-label + i.field-icon,
        .field-wrap input:focus ~ i.field-icon {
            color: var(--accent);
        }

        .form-control-dark {
            width: 100%;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 14px;
            padding: 14px 18px 14px 46px;
            font-size: 0.9rem;
            color: #fff;
            transition: all 0.3s;
            outline: none;
            font-family: 'Inter', sans-serif;
        }
        .form-control-dark::placeholder { color: rgba(255,255,255,0.3); }
        .form-control-dark:focus {
            border-color: var(--accent);
            background: rgba(0,240,255,0.05);
            box-shadow: 0 0 0 3px rgba(0,240,255,0.12);
        }

        /* password toggle */
        .pw-toggle {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: rgba(255,255,255,0.35);
            cursor: pointer;
            font-size: 16px;
            padding: 4px;
            transition: color 0.3s;
        }
        .pw-toggle:hover { color: var(--accent); }

        /* remember / forgot */
        .form-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 4px 0 20px;
        }
        .remember-check { display: flex; align-items: center; gap: 8px; }
        .remember-check input[type="checkbox"] {
            width: 16px; height: 16px;
            accent-color: var(--accent);
            cursor: pointer;
        }
        .remember-check label {
            font-size: 0.82rem;
            color: rgba(255,255,255,0.55);
            cursor: pointer;
        }
        .forgot-link {
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--accent);
            text-decoration: none;
            transition: opacity 0.2s;
        }
        .forgot-link:hover { opacity: 0.75; }

        /* validation */
        .text-danger { font-size: 0.75rem; color: #f87171 !important; margin-top: 4px; display: block; }

        /* submit button */
        .btn-login {
            width: 100%;
            padding: 15px;
            border: none;
            border-radius: 14px;
            background: linear-gradient(135deg, var(--purple) 0%, var(--pink) 100%);
            color: #fff;
            font-size: 0.95rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 8px 24px rgba(124,58,237,0.4);
            position: relative;
            overflow: hidden;
        }
        .btn-login::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.15), transparent);
            opacity: 0;
            transition: opacity 0.3s;
        }
        .btn-login:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(124,58,237,0.5); }
        .btn-login:hover::before { opacity: 1; }
        .btn-login:active { transform: translateY(0); }

        /* loading spinner */
        .btn-login.loading { color: transparent; }
        .btn-login.loading::after {
            content: '';
            position: absolute;
            width: 20px; height: 20px;
            top: 50%; left: 50%;
            margin: -10px 0 0 -10px;
            border: 2px solid rgba(255,255,255,0.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }

        /* divider */
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 20px 0;
            color: rgba(255,255,255,0.25);
            font-size: 0.78rem;
            letter-spacing: 1px;
            text-transform: uppercase;
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(255,255,255,0.1);
        }

        /* Google button */
        .btn-google {
            width: 100%;
            padding: 13px;
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 14px;
            background: rgba(255,255,255,0.05);
            color: rgba(255,255,255,0.8);
            font-size: 0.88rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            cursor: pointer;
            transition: all 0.3s;
            font-family: 'Inter', sans-serif;
        }
        .btn-google:hover {
            background: rgba(255,255,255,0.1);
            border-color: rgba(255,255,255,0.22);
            transform: translateY(-1px);
        }
        .btn-google img { width: 18px; }

        /* register link */
        .register-row {
            text-align: center;
            margin-top: 20px;
            font-size: 0.83rem;
            color: rgba(255,255,255,0.4);
        }
        .register-row a {
            color: var(--accent);
            font-weight: 600;
            text-decoration: none;
        }
        .register-row a:hover { opacity: 0.8; }

        /* validation alert */
        .alert-glass {
            background: rgba(248,113,113,0.12);
            border: 1px solid rgba(248,113,113,0.3);
            border-radius: 12px;
            padding: 12px 16px;
            color: #fca5a5;
            font-size: 0.85rem;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* ─── Responsive ─── */
        @Html.Raw("@media") (max-width: 900px) {
            .page-wrap { grid-template-columns: 1fr; max-width: 520px; padding: 32px 20px; gap: 24px; min-height: unset; }
            .brand-panel { display: none; }
            body { overflow: auto; }
        }
        @Html.Raw("@media") (max-width: 480px) {
            .form-card { padding: 32px 24px; border-radius: 20px; }
        }
    </style>
</head>
<body>
    <!-- Animated background -->
    <div class="bg-scene">
        <div class="bg-image"></div>
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
    </div>

    <div class="page-wrap">
        <!-- ─── LEFT: Brand panel ─── -->
        <div class="brand-panel">
            <div class="logo-pill">
                <i class="bi bi-lightning-charge-fill"></i>
                <span>Power Fitness</span>
            </div>

            <h1 class="brand-headline">
                Your body can<br>
                <span class="grad">stand almost</span><br>
                anything.
            </h1>

            <p class="brand-sub">
                It's your mind that needs convincing. Push past your limits,
                stay committed, and watch your body transform.
            </p>

            <ul class="feature-list">
                <li><i class="bi bi-trophy-fill"></i> Gamified badges &amp; achievement streaks</li>
                <li><i class="bi bi-graph-up-arrow"></i> Real-time analytics &amp; progress tracking</li>
                <li><i class="bi bi-people-fill"></i> Trainer management &amp; session scheduling</li>
                <li><i class="bi bi-shield-lock-fill"></i> Secure role-based access control</li>
            </ul>

            <div class="stat-chips">
                <div class="chip">
                    <span class="chip-num">500+</span>
                    <span class="chip-label">Members</span>
                </div>
                <div class="chip">
                    <span class="chip-num">50+</span>
                    <span class="chip-label">Trainers</span>
                </div>
                <div class="chip">
                    <span class="chip-num">24/7</span>
                    <span class="chip-label">Support</span>
                </div>
            </div>
        </div>

        <!-- ─── RIGHT: Login card ─── -->
        <div class="form-card">
            <div class="form-header">
                <div class="auth-icon">
                    <i class="bi bi-lightning-charge-fill"></i>
                </div>
                <h2>Welcome back</h2>
                <p>Sign in to your Power Fitness account</p>
            </div>

            @{
                var hasErrors = !ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0;
            }
            @if (hasErrors)
            {
                <div class="alert-glass">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    @Html.ValidationMessage("InvalidLogin")
                </div>
            }

            <form asp-action="Login" asp-controller="Account" method="post" id="loginForm">

                <!-- Email -->
                <div class="field-wrap">
                    <input asp-for="Email"
                           class="form-control-dark"
                           id="emailInput"
                           placeholder="your@email.com"
                           autocomplete="username" />
                    <i class="bi bi-envelope field-icon"></i>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <!-- Password -->
                <div class="field-wrap">
                    <input asp-for="Password"
                           class="form-control-dark"
                           id="passwordInput"
                           placeholder="Password"
                           autocomplete="current-password" />
                    <i class="bi bi-lock-fill field-icon"></i>
                    <button type="button" class="pw-toggle" id="pwToggle" aria-label="Show password">
                        <i class="bi bi-eye" id="pwIcon"></i>
                    </button>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <!-- Remember / Forgot -->
                <div class="form-meta">
                    <div class="remember-check">
                        <input asp-for="RememberMe" type="checkbox" id="rememberMe">
                        <label for="rememberMe">Remember me</label>
                    </div>
                    <a asp-controller="Account" asp-action="ForgotPassword" class="forgot-link">Forgot Password?</a>
                </div>

                <div asp-validation-summary="All" class="text-danger" style="font-size:0.78rem;margin-bottom:10px;"></div>

                <button type="submit" class="btn-login" id="loginBtn">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>
            </form>

            <div class="divider">or continue with</div>

            <form asp-controller="Account" asp-action="ExternalLogin" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="provider" value="Google" />
                <button type="submit" class="btn-google">
                    <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google" />
                    Continue with Google
                </button>
            </form>

            <div class="register-row">
                Don't have an account? <a asp-controller="Account" asp-action="Register">Create one</a>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Auto focus email
        document.getElementById('emailInput').focus();

        // Loading state on submit
        document.getElementById('loginForm').addEventListener('submit', function () {
            if ($(this).valid()) {
                const btn = document.getElementById('loginBtn');
                btn.classList.add('loading');
                btn.disabled = true;
            }
        });

        // Password toggle
        document.getElementById('pwToggle').addEventListener('click', function () {
            const input = document.getElementById('passwordInput');
            const icon  = document.getElementById('pwIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye';
            }
        });
    </script>
</body>
</html>
