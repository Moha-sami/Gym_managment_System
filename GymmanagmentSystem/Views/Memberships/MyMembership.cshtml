@model GymMangment.BLL.ViewModels.MembershipViewModels.MyMembershipViewModel
@{
    ViewData["Title"] = "My Membership";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header @(Model.IsActive ? "bg-primary-color" : "bg-secondary") text-white text-center py-5">
                    <i class="bi bi-card-checklist display-4 mb-3"></i>
                    <h2 class="mb-0">@Model.PlanName</h2>
                    <span class="badge bg-light text-dark mt-2">@(Model.IsActive ? "Active" : "Expired")</span>
                </div>
                <div class="card-body p-4">
                    <div class="text-center mb-4 py-3 bg-light rounded">
                        <div class="display-4 fw-bold text-primary-color">@Model.Price.ToString("0")</div>
                        <small class="text-muted fs-5">EGP</small>
                    </div>

                    <p class="text-center text-muted mb-4">@Model.PlanDescription</p>

                    <div class="row g-3">
                        <div class="col-6">
                            <div class="p-3 bg-light rounded text-center">
                                <small class="text-muted d-block">Start Date</small>
                                <strong>@Model.StartDate.ToString("MMM dd, yyyy")</strong>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 bg-light rounded text-center">
                                <small class="text-muted d-block">End Date</small>
                                <strong>@Model.EndDate.ToString("MMM dd, yyyy")</strong>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="p-3 bg-light rounded text-center">
                                <small class="text-muted d-block">Days Remaining</small>
                                <strong class="@(Model.DaysRemaining <= 3 ? "text-danger" : "text-primary-color") fs-4">
                                    @Model.DaysRemaining days
                                </strong>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white border-0 p-4">
                    <a asp-controller="Plans" asp-action="Index" class="btn btn-fill w-100">
                        <i class="bi bi-arrow-repeat me-1"></i>View Other Plans
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>