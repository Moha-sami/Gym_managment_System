@using GymMangment.BLL.ViewModels.MembershipViewModels
@model MembershipViewModel
@{
    ViewData["Title"] = "Delete Membership";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card p-5 shadow text-center">
                <p class="fs-3 text-primary-color mb-4">
                    Are you sure you want to delete <strong>@Model.MemberName</strong>'s membership?
                </p>
                <div class="alert alert-warning text-start" role="alert">
                    <strong>Warning!</strong> This action cannot be undone. The membership will be permanently deleted.
                </div>
                <form asp-controller="Memberships" asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post" class="mt-4">
                    <div class="buttons d-flex justify-content-between gap-3">
                        <a asp-controller="Memberships" asp-action="Index" class="btn-outline flex-fill">NO</a>
                        <button type="submit" class="btn-fill flex-fill">Yes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
