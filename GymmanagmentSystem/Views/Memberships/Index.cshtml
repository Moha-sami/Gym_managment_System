@using GymMangment.BLL.ViewModels.MembershipViewModels
@model IEnumerable<MembershipViewModel>
@{
    ViewData["Title"] = "Memberships";
}

<div class="container">
    <header class="d-flex justify-content-between mt-5 mb-4 align-items-center">
        <div>
            <h2 class="text-primary-color mb-0">Memberships</h2>
            <p class="text-muted">Manage member subscriptions and plans</p>
        </div>
        <a asp-controller="Memberships" asp-action="Create" class="btn btn-fill fw-medium rounded-pill px-4 py-3">
            <i class="bi bi-plus-lg me-2"></i>Add Membership
        </a>
    </header>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-borderless">
                <thead>
                    <tr>
                        <th><span>Member</span></th>
                        <th><span>Plan</span></th>
                        <th><span>Start Date</span></th>
                        <th><span>End Date</span></th>
                        <th><span>Status</span></th>
                        <th><span>Action</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var membership in Model)
                    {
                        <tr>
                            <td><span class="fw-bold">@membership.MemberName</span></td>
                            <td><span>@membership.PlanName</span></td>
                            <td><span>@membership.StartDate.ToString("MMM dd, yyyy")</span></td>
                            <td><span>@membership.EndDate.ToString("MMM dd, yyyy")</span></td>
                            <td>
                                <span class="badge @(membership.IsActive ? "bg-primary-color" : "bg-secondary")">
                                    @membership.Status
                                </span>
                            </td>
                            <td class="action position-relative">
                                <div class="dropdown">
                                    <button class="btn btn-link p-0 border-0" type="button"
                                            id="dropdownMenuButton-@membership.Id"
                                            data-bs-toggle="dropdown" aria-expanded="false">
                                        <img src="~/images/action dots.jpg" alt="action icon" />
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-start" aria-labelledby="dropdownMenuButton-@membership.Id">
                                        <li>
                                            <a asp-controller="Memberships" asp-action="Details" asp-route-id="@membership.Id"
                                               class="dropdown-item d-flex align-items-center gap-3">
                                                <i class="bi bi-eye text-primary-color"></i>
                                                <span>View Details</span>
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a asp-controller="Memberships" asp-action="Delete" asp-route-id="@membership.Id"
                                               class="dropdown-item d-flex align-items-center gap-3 text-danger">
                                                <i class="bi bi-trash"></i>
                                                <span>Delete</span>
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-person-badge display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No Memberships Available</h4>
            <p class="text-muted">Add your first membership to get started</p>
        </div>
    }
</div>
