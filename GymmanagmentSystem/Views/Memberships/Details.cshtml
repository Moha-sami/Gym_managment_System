@using GymMangment.BLL.ViewModels.MembershipViewModels
@model MembershipViewModel
@{
    ViewData["Title"] = "Membership Details";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header @(Model.IsActive ? "bg-primary-color" : "bg-secondary") text-white text-center py-5">
                    <i class="bi bi-person-badge display-4 mb-3"></i>
                    <h2 class="mb-0">@Model.MemberName</h2>
                    <span class="badge bg-light text-dark mt-2">@Model.Status</span>
                </div>
                <div class="card-body p-4">
                    <div class="plan-details">
                        <div class="detail-item mb-4">
                            <div class="d-flex align-items-center mb-2">
                                <div class="icon-box me-3">
                                    <i class="bi bi-card-checklist text-primary-color fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 text-muted">Plan</h6>
                                    <p class="mb-0 fw-bold">@Model.PlanName</p>
                                </div>
                            </div>
                        </div>

                        <div class="detail-item mb-4">
                            <div class="d-flex align-items-center mb-2">
                                <div class="icon-box me-3">
                                    <i class="bi bi-calendar-check text-primary-color fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 text-muted">Start Date</h6>
                                    <p class="mb-0 fw-bold">@Model.StartDate.ToString("MMM dd, yyyy")</p>
                                </div>
                            </div>
                        </div>

                        <div class="detail-item mb-4">
                            <div class="d-flex align-items-center mb-2">
                                <div class="icon-box me-3">
                                    <i class="bi bi-calendar-x text-primary-color fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 text-muted">End Date</h6>
                                    <p class="mb-0 fw-bold">@Model.EndDate.ToString("MMM dd, yyyy")</p>
                                </div>
                            </div>
                        </div>

                        <div class="detail-item mb-4">
                            <div class="d-flex align-items-center mb-2">
                                <div class="icon-box me-3">
                                    <i class="bi @(Model.IsActive ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger") fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 text-muted">Status</h6>
                                    <p class="mb-0">
                                        @if (Model.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Expired</span>
                                        }
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white border-0 p-4">
                    <a asp-controller="Memberships" asp-action="Index" class="btn btn-outline flex-fill w-100">
                        <i class="bi bi-arrow-left me-1"></i>Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
