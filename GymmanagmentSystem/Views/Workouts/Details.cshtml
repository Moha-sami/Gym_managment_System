@using GymMangment.BLL.ViewModels.WorkoutViewModels
@model WorkoutLogViewModel
@{
    ViewData["Title"] = Model.Name + " Details";
}

<div class="container py-5">
    <div class="mb-4">
        <a asp-action="MyJournal" class="btn btn-outline-secondary rounded-pill px-3 py-2">
            <i class="bi bi-arrow-left me-2"></i>Back to Journal
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4 p-md-5">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                <div>
                    <h1 class="fw-bold text-dark mb-2">@Model.Name</h1>
                    <span class="fs-5 text-primary-color font-monospace">
                        <i class="bi bi-calendar3 me-2"></i>@Model.Date.ToString("dddd, MMMM dd, yyyy")
                    </span>
                </div>
                
                @if (Model.Exercises.Any())
                {
                    <div class="bg-light rounded-4 px-4 py-3 border text-center">
                        <div class="text-uppercase font-monospace text-muted mb-1" style="font-size: 0.75rem;">Total Workout Volume</div>
                        <div class="h3 fw-bold text-success mb-0">@Model.TotalVolume.ToString("N0") <span class="fs-6 text-muted">kg</span></div>
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="p-3 bg-light rounded-3 border-start border-primary border-4 mb-0">
                    <p class="mb-0 text-muted" style="font-style: italic;">
                        <i class="bi bi-chat-left-quote-fill me-2 text-primary-color fs-5"></i>
                        "@Model.Notes"
                    </p>
                </div>
            }
        </div>
    </div>

    @if (Model.Exercises != null && Model.Exercises.Any())
    {
        <h3 class="fw-bold text-dark mb-4 mt-5">Exercises Logged (@Model.Exercises.Count)</h3>
        
        <div class="row g-4">
            @foreach (var exercise in Model.Exercises)
            {
                <div class="col-12 col-lg-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
                        <div class="card-header bg-light border-0 py-3 px-4 d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold text-dark mb-0"><i class="bi bi-activity text-primary-color me-2"></i> @exercise.ExerciseName</h5>
                            <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2 border border-success border-opacity-25" style="font-size: 0.85rem;">
                                Max: @exercise.MaxWeight.ToString("G29") kg
                            </span>
                        </div>
                        <div class="card-body p-4">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead>
                                        <tr class="table-light">
                                            <th class="text-center font-monospace" style="width: 15%;">Set</th>
                                            <th class="text-end" style="width: 30%;">Weight</th>
                                            <th class="text-end" style="width: 25%;">Reps</th>
                                            <th class="text-end" style="width: 30%;">Volume</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var set in exercise.Sets)
                                        {
                                            var setVolume = set.Weight * set.Reps;
                                            <tr>
                                                <td class="text-center font-monospace fw-bold text-muted">@set.SetNumber</td>
                                                <td class="text-end fw-bold">@set.Weight.ToString("G29") <span class="fw-normal text-muted fs-7">kg</span></td>
                                                <td class="text-end fw-bold text-dark">@set.Reps</td>
                                                <td class="text-end text-muted">@setVolume.ToString("N0") <span class="fs-7">kg</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            
                            <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top text-muted font-monospace" style="font-size: 0.85rem;">
                                <span>Total Sets: @exercise.Sets.Count</span>
                                <span>Volume: @exercise.Volume.ToString("N0") kg</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-white border rounded-4 shadow-sm mt-5">
            <i class="bi bi-list-stars display-2 text-muted opacity-50"></i>
            <h4 class="mt-3 text-muted">No Exercises Logged</h4>
            <p class="text-muted">This workout log has no exercises or sets recorded.</p>
        </div>
    }
</div>

<style>
    .fs-7 {
        font-size: 0.75rem;
    }
    .bg-success-subtle {
        background-color: rgba(25, 135, 84, 0.1) !important;
    }
</style>
