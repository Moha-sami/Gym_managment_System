@using GymMangment.BLL.ViewModels.WorkoutViewModels
@model IEnumerable<WorkoutLogViewModel>
@{
    ViewData["Title"] = "My Workout Journal";
}

<div class="container py-5">
    <header class="d-flex justify-content-between mb-5 align-items-center flex-wrap gap-3">
        <div>
            <h2 class="text-primary-color mb-1 font-title fw-bold">My Workout Journal</h2>
            <p class="text-muted mb-0">Track your daily exercises, weights, and sets in one place.</p>
        </div>
        <a asp-action="Create" class="btn btn-fill fw-medium rounded-pill px-4 py-3 shadow-sm transition-all hover-scale">
            <i class="bi bi-plus-circle-fill me-2"></i>Log a Workout
        </a>
    </header>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4 py-3" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-check-circle-fill fs-4 me-3 text-success"></i>
                <div>@TempData["SuccessMessage"]</div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4 py-3" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-exclamation-triangle-fill fs-4 me-3 text-danger"></i>
                <div>@TempData["ErrorMessage"]</div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var workout in Model)
            {
                var totalSets = workout.Exercises.Sum(e => e.Sets.Count);
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100 rounded-4 overflow-hidden card-hover transition-all">
                        <div class="card-header bg-light border-0 py-3 d-flex justify-content-between align-items-center">
                            <span class="badge bg-primary-color rounded-pill px-3 py-2 text-white font-monospace">
                                <i class="bi bi-calendar3 me-1"></i> @workout.Date.ToString("MMM dd, yyyy")
                            </span>
                            <form asp-action="Delete" asp-route-id="@workout.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this workout log?');" class="d-inline">
                                <button type="submit" class="btn btn-link text-muted p-0 hover-danger" title="Delete Log">
                                    <i class="bi bi-trash fs-5"></i>
                                </button>
                            </form>
                        </div>
                        <div class="card-body p-4 d-flex flex-column justify-content-between">
                            <div>
                                <h4 class="card-title fw-bold text-dark mb-2">@workout.Name</h4>
                                @if (!string.IsNullOrEmpty(workout.Notes))
                                {
                                    <p class="card-text text-muted mb-4 font-italic text-truncate-2" style="font-size: 0.9rem;">
                                        <i class="bi bi-chat-left-text me-1"></i> "@workout.Notes"
                                    </p>
                                }
                                else
                                {
                                    <p class="card-text text-muted mb-4 opacity-50 font-italic" style="font-size: 0.9rem;">
                                        <i class="bi bi-chat-left-text-fill me-1"></i> No training notes.
                                    </p>
                                }

                                <div class="d-flex gap-3 mb-4">
                                    <div class="bg-light rounded-3 p-3 flex-fill text-center border">
                                        <div class="fw-bold text-primary-color fs-4">@workout.Exercises.Count</div>
                                        <div class="text-muted text-uppercase font-monospace" style="font-size: 0.75rem;">Exercises</div>
                                    </div>
                                    <div class="bg-light rounded-3 p-3 flex-fill text-center border">
                                        <div class="fw-bold text-success fs-4">@totalSets</div>
                                        <div class="text-muted text-uppercase font-monospace" style="font-size: 0.75rem;">Total Sets</div>
                                    </div>
                                </div>
                            </div>

                            <div class="d-grid mt-auto">
                                <a asp-action="Details" asp-route-id="@workout.Id" class="btn btn-outline-primary rounded-pill py-2.5 hover-scale">
                                    <i class="bi bi-eye-fill me-2"></i>View Exercises
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-white border rounded-4 shadow-sm">
            <div class="mb-4">
                <i class="bi bi-journal-medical display-1 text-muted opacity-50"></i>
            </div>
            <h3 class="fw-bold text-dark">Your Journal is Empty</h3>
            <p class="text-muted max-w-lg mx-auto px-3 mb-4">You haven't logged any workouts yet. Keep track of your progress and exercises by logging your first workout today!</p>
            <a asp-action="Create" class="btn btn-fill fw-medium rounded-pill px-5 py-3 hover-scale">
                <i class="bi bi-plus-circle-fill me-2"></i>Log Your First Workout
            </a>
        </div>
    }
</div>

<style>
    .card-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.08) !important;
    }
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
    .hover-danger:hover {
        color: #dc3545 !important;
    }
    .transition-all {
        transition: all 0.25s ease-in-out;
    }
</style>
