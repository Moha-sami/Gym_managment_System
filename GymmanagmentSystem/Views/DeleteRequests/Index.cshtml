@using GymManagment.DAL.Models
@using GymManagment.DAL.Models.Enum
@model IEnumerable<DeleteRequest>
@{
    ViewData["Title"] = "Delete Requests";
}

<div class="container">
    <header class="d-flex justify-content-between mt-5 mb-4 align-items-center">
        <div>
            <h2 class="text-primary-color mb-0">Delete Requests</h2>
            <p class="text-muted">Review manager requests before anything is removed</p>
        </div>
    </header>

    @if (Model.Any())
    {
        <div class="table-responsive" style="overflow: visible;">
            <table class="table table-borderless align-middle responsive-card-table">
                <thead>
                    <tr>
                        <th><span>Target</span></th>
                        <th><span>Requested By</span></th>
                        <th><span>Requested At</span></th>
                        <th><span>Status</span></th>
                        <th><span>Reason</span></th>
                        <th><span>Action</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model)
                    {
                        var statusClass = request.Status switch
                        {
                            DeleteRequestStatus.Pending => "bg-warning text-dark",
                            DeleteRequestStatus.Approved => "bg-success",
                            DeleteRequestStatus.Rejected => "bg-secondary",
                            _ => "bg-secondary"
                        };

                        <tr>
                            <td data-label="Target">
                                <strong>@request.TargetType</strong>
                                <span class="d-block text-muted">@request.TargetName</span>
                            </td>
                            <td data-label="Requested By">
                                <span>@request.RequestedByName</span>
                            </td>
                            <td data-label="Requested At">
                                <span>@request.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</span>
                            </td>
                            <td data-label="Status">
                                <span class="badge @statusClass">@request.Status</span>
                                @if (request.ReviewedAt.HasValue)
                                {
                                    <small class="d-block text-muted mt-1">
                                        by @request.ReviewedByName
                                    </small>
                                }
                            </td>
                            <td data-label="Reason">
                                <span>@(string.IsNullOrWhiteSpace(request.Reason) ? "No reason provided" : request.Reason)</span>
                                @if (!string.IsNullOrWhiteSpace(request.AdminNote))
                                {
                                    <small class="d-block text-muted mt-1">Admin note: @request.AdminNote</small>
                                }
                            </td>
                             <td data-label="Action">
                                 @if (request.Status == DeleteRequestStatus.Pending)
                                 {
                                     <div class="d-flex flex-column gap-2 w-100 mx-auto" style="max-width: 280px;">
                                         <input id="note-@request.Id" class="form-control form-control-sm border-muted shadow-sm" placeholder="Optional review note..." />
                                         <div class="d-flex gap-2">
                                             <form asp-controller="DeleteRequests" asp-action="Approve" asp-route-id="@request.Id" method="post" class="flex-fill" onsubmit="syncNote(@request.Id, this)">
                                                 <input type="hidden" name="adminNote" id="approve-note-@request.Id" />
                                                 <button type="submit" class="btn btn-danger btn-sm w-100 rounded-pill shadow-sm d-flex align-items-center justify-content-center gap-1 py-1">
                                                     <i class="bi bi-check-circle-fill"></i> Approve
                                                 </button>
                                             </form>
                                             <form asp-controller="DeleteRequests" asp-action="Reject" asp-route-id="@request.Id" method="post" class="flex-fill" onsubmit="syncNote(@request.Id, this)">
                                                 <input type="hidden" name="adminNote" id="reject-note-@request.Id" />
                                                 <button type="submit" class="btn btn-outline-secondary btn-sm w-100 rounded-pill shadow-sm d-flex align-items-center justify-content-center gap-1 py-1">
                                                     <i class="bi bi-x-circle-fill"></i> Reject
                                                 </button>
                                             </form>
                                         </div>
                                     </div>
                                 }
                                 else
                                 {
                                     <span class="badge bg-light text-muted border py-2 px-3 rounded-pill"><i class="bi bi-check-all me-1"></i>Reviewed</span>
                                 }
                             </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No Delete Requests</h4>
            <p class="text-muted">Manager delete requests will appear here</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        function syncNote(requestId, form) {
            var noteVal = document.getElementById('note-' + requestId).value;
            $(form).find('input[name="adminNote"]').val(noteVal);
        }
    </script>
}
