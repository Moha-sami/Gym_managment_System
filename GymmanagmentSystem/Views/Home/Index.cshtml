@using GymMangment.BLL.ViewModels
@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var isMember = User.IsInRole("Member");
}

<style>
    /* ── Command Hub Base ── */
    .command-hub {
        color: #fff;
        max-width: 1400px;
        margin: 0 auto;
    }

    /* ── Hero Banner ── */
    .hero-banner {
        background: linear-gradient(135deg, rgba(124,58,237,0.15), rgba(219,39,119,0.1), rgba(0,240,255,0.05));
        border: 1px solid rgba(255,255,255,0.1);
        backdrop-filter: blur(20px);
        border-radius: 28px;
        padding: 40px;
        margin-bottom: 36px;
        position: relative;
        overflow: hidden;
    }
    .hero-banner::before {
        content: '';
        position: absolute;
        top: -50%; right: -20%;
        width: 400px; height: 400px;
        background: radial-gradient(circle, rgba(0,240,255,0.15), transparent 70%);
        pointer-events: none;
    }

    .hero-title {
        font-size: clamp(1.8rem, 3.5vw, 2.8rem);
        font-weight: 800;
        letter-spacing: -0.5px;
        line-height: 1.15;
        margin-bottom: 12px;
    }

    .text-grad-cyan {
        background: linear-gradient(135deg, #00f0ff 0%, #7c3aed 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .text-grad-pink {
        background: linear-gradient(135deg, #db2777 0%, #ff7b00 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .hero-sub {
        color: rgba(255,255,255,0.65);
        font-size: 1rem;
        max-width: 650px;
        margin-bottom: 24px;
        line-height: 1.6;
    }

    /* ── Section Title ── */
    .section-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }
    .section-header h3 {
        font-size: 1.25rem;
        font-weight: 700;
        margin: 0;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.9);
    }
    .section-header i { font-size: 1.3rem; color: #00f0ff; }

    /* ── Quick Nav Hub Cards ── */
    .nav-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }

    .hub-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        backdrop-filter: blur(16px);
        border-radius: 24px;
        padding: 28px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
        text-decoration: none;
        color: #fff;
        position: relative;
        overflow: hidden;
    }
    .hub-card::after {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 100%; height: 3px;
        background: linear-gradient(90deg, var(--card-color, #00f0ff), transparent);
        opacity: 0.4;
        transition: opacity 0.3s;
    }
    .hub-card:hover {
        transform: translateY(-6px);
        background: rgba(255,255,255,0.06);
        border-color: rgba(255,255,255,0.18);
        box-shadow: 0 16px 40px rgba(0,0,0,0.4);
        color: #fff;
    }
    .hub-card:hover::after { opacity: 1; }

    .hub-icon-wrap {
        width: 54px; height: 54px;
        border-radius: 16px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 20px;
        color: var(--card-color, #00f0ff);
        box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    }

    .hub-card-title {
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 8px;
        color: #fff;
    }

    .hub-card-desc {
        font-size: 0.85rem;
        color: rgba(255,255,255,0.55);
        line-height: 1.5;
        margin-bottom: 24px;
    }

    .hub-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--card-color, #00f0ff);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: gap 0.2s;
    }
    .hub-card:hover .hub-btn { gap: 12px; }

    /* ── Dashboard Gauges ── */
    .dashboard-gauges { width: 100%; }
    .gauges-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }
    .gauge-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 20px 14px;
        border-radius: 20px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        backdrop-filter: blur(16px);
        transition: transform 0.3s ease;
    }
    .gauge-card:hover { transform: translateY(-4px); background: rgba(255,255,255,0.05); }
    .gauge-svg { width: 100%; max-width: 110px; overflow: visible; }
    .gauge-track { fill: none; stroke: rgba(255,255,255,0.06); stroke-width: 8; stroke-linecap: round; }
    .gauge-fill {
        fill: none; stroke-width: 8; stroke-linecap: round;
        stroke-dasharray: 314; stroke-dashoffset: calc(314 * (1 - var(--pct)));
        transform-origin: 60px 60px; transform: rotate(-90deg);
        transition: stroke-dashoffset 1.4s cubic-bezier(0.16,1,0.3,1);
        filter: drop-shadow(0 0 8px currentColor);
    }
    .gauge-val { fill: #fff; font-size: 22px; font-weight: 800; font-family: 'Inter', sans-serif; }
    .gauge-lbl { fill: rgba(255,255,255,0.45); font-size: 10px; text-transform: uppercase; letter-spacing: 1.5px; font-family: 'Inter', sans-serif; }
    .gauge-sm { flex-direction: column; gap: 4px; padding: 16px 12px; }
    .gauge-icon { font-size: 1.5rem; margin-bottom: 2px; }
    .gauge-num  { font-size: 1.6rem; font-weight: 800; line-height: 1; }
    .gauge-name { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,0.45); }

    /* ── Ticker Bar ── */
    .ticker-bar {
        background: rgba(124,58,237,0.15);
        border: 1px solid rgba(124,58,237,0.25);
        border-radius: 16px;
        padding: 16px;
        overflow: hidden;
        margin-top: 40px;
    }
    .ticker-content {
        display: flex;
        align-items: center;
        gap: 24px;
        white-space: nowrap;
        font-weight: 700;
        font-size: 0.9rem;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        color: #fff;
    }
</style>

<div class="command-hub">

    @if (isMember)
    {
        <!-- ── Member Hero Banner ── -->
        <div class="hero-banner">
            <h1 class="hero-title">
                WELCOME BACK, <span class="text-grad-cyan">CHAMPION</span>
            </h1>
            <p class="hero-sub">
                Track your workouts, level up your achievements, book fitness sessions, and monitor your progress all from your personal control center.
            </p>
            <div class="d-flex flex-wrap gap-3">
                <a asp-controller="Workouts" asp-action="MyJournal" class="btn btn-neon rounded-pill px-4 py-2.5">
                    <i class="bi bi-journal-plus me-2"></i> Log Workout
                </a>
                <a asp-controller="SessionsSchedule" asp-action="Index" class="btn border border-white-20 text-white rounded-pill px-4 py-2.5 bg-transparent" style="backdrop-filter:blur(10px);">
                    <i class="bi bi-calendar-event me-2"></i> Book Class
                </a>
            </div>
        </div>

        <!-- ── Navigation Action Cards ── -->
        <div class="section-header">
            <i class="bi bi-compass"></i>
            <h3>Quick Navigation Hub</h3>
        </div>

        <div class="nav-grid">

            <!-- 1. Workout Journal -->
            <a asp-controller="Workouts" asp-action="MyJournal" class="hub-card" style="--card-color: #00f0ff;">
                <div>
                    <div class="hub-icon-wrap">
                        <i class="bi bi-journal-bookmark-fill"></i>
                    </div>
                    <div class="hub-card-title">Workout Journal</div>
                    <div class="hub-card-desc">
                        Log your daily sets, record heavy lifts, track volume history, and build your strength streak.
                    </div>
                </div>
                <div class="hub-btn">
                    Open Journal <i class="bi bi-arrow-right"></i>
                </div>
            </a>

            <!-- 2. Achievements & Badges -->
            <a asp-controller="Achievements" asp-action="MyAchievements" class="hub-card" style="--card-color: #7c3aed;">
                <div>
                    <div class="hub-icon-wrap">
                        <i class="bi bi-award-fill"></i>
                    </div>
                    <div class="hub-card-title">My Achievements</div>
                    <div class="hub-card-desc">
                        Inspect earned badges, check your workout streak, and unlock new gamification milestones.
                    </div>
                </div>
                <div class="hub-btn">
                    View Badges <i class="bi bi-arrow-right"></i>
                </div>
            </a>

            <!-- 3. Sessions & Schedule -->
            <a asp-controller="SessionsSchedule" asp-action="Index" class="hub-card" style="--card-color: #db2777;">
                <div>
                    <div class="hub-icon-wrap">
                        <i class="bi bi-calendar3"></i>
                    </div>
                    <div class="hub-card-title">Sessions Schedule</div>
                    <div class="hub-card-desc">
                        Explore upcoming group training, reserve seats for live classes, and view trainer schedules.
                    </div>
                </div>
                <div class="hub-btn">
                    Book Session <i class="bi bi-arrow-right"></i>
                </div>
            </a>

            <!-- 4. Leaderboard -->
            <a asp-controller="Achievements" asp-action="Leaderboard" class="hub-card" style="--card-color: #ff7b00;">
                <div>
                    <div class="hub-icon-wrap">
                        <i class="bi bi-trophy-fill"></i>
                    </div>
                    <div class="hub-card-title">Leaderboard</div>
                    <div class="hub-card-desc">
                        See where you rank among gym members, compare total XP, and rise to top position.
                    </div>
                </div>
                <div class="hub-btn">
                    View Rankings <i class="bi bi-arrow-right"></i>
                </div>
            </a>

            <!-- 5. Exercise Library -->
            <a asp-controller="Exercises" asp-action="Index" class="hub-card" style="--card-color: #22c55e;">
                <div>
                    <div class="hub-icon-wrap">
                        <i class="bi bi-activity"></i>
                    </div>
                    <div class="hub-card-title">Exercise Library</div>
                    <div class="hub-card-desc">
                        Browse exercises by targeted muscle groups, review movement guides, and learn ideal form.
                    </div>
                </div>
                <div class="hub-btn">
                    Explore Library <i class="bi bi-arrow-right"></i>
                </div>
            </a>

            <!-- 6. My Profile -->
            <a asp-controller="Members" asp-action="MyProfile" class="hub-card" style="--card-color: #38bdf8;">
                <div>
                    <div class="hub-icon-wrap">
                        <i class="bi bi-person-bounding-box"></i>
                    </div>
                    <div class="hub-card-title">My Profile &amp; Plan</div>
                    <div class="hub-card-desc">
                        Review active membership status, update medical metrics, and view subscription details.
                    </div>
                </div>
                <div class="hub-btn">
                    View Profile <i class="bi bi-arrow-right"></i>
                </div>
            </a>

        </div>
    }
    else
    {
        <!-- ── Admin / Staff Console Banner ── -->
        <div class="hero-banner">
            <h1 class="hero-title">
                GYM SYSTEM <span class="text-grad-cyan">ANALYTICS CONSOLE</span>
            </h1>
            <p class="hero-sub">
                Real-time active member count, facility capacity metrics, class participation numbers, and trainer allocations.
            </p>
        </div>

        <div class="section-header">
            <i class="bi bi-speedometer2"></i>
            <h3>Live Facility Overview</h3>
        </div>

        <div class="dashboard-gauges mb-4">
            <div class="gauges-grid">
                <div class="gauge-card">
                    <div class="gauge-ring" data-value="@Model.TotalMembers" data-max="1000" data-color="#00f0ff">
                        <svg viewBox="0 0 120 120" class="gauge-svg">
                            <circle class="gauge-track" cx="60" cy="60" r="50" />
                            <circle class="gauge-fill" cx="60" cy="60" r="50" style="--pct:0; stroke:#00f0ff;" />
                            <text class="gauge-val" x="60" y="56" text-anchor="middle" dy=".3em">@Model.TotalMembers</text>
                            <text class="gauge-lbl" x="60" y="78" text-anchor="middle">Members</text>
                        </svg>
                    </div>
                </div>
                <div class="gauge-card">
                    <div class="gauge-ring" data-value="@Model.ActiveMembers" data-max="1000" data-color="#7c3aed">
                        <svg viewBox="0 0 120 120" class="gauge-svg">
                            <circle class="gauge-track" cx="60" cy="60" r="50" />
                            <circle class="gauge-fill" cx="60" cy="60" r="50" style="--pct:0; stroke:#7c3aed;" />
                            <text class="gauge-val" x="60" y="56" text-anchor="middle" dy=".3em">@Model.ActiveMembers</text>
                            <text class="gauge-lbl" x="60" y="78" text-anchor="middle">Active</text>
                        </svg>
                    </div>
                </div>
                <div class="gauge-card">
                    <div class="gauge-ring" data-value="@Model.TotalTrainers" data-max="100" data-color="#db2777">
                        <svg viewBox="0 0 120 120" class="gauge-svg">
                            <circle class="gauge-track" cx="60" cy="60" r="50" />
                            <circle class="gauge-fill" cx="60" cy="60" r="50" style="--pct:0; stroke:#db2777;" />
                            <text class="gauge-val" x="60" y="56" text-anchor="middle" dy=".3em">@Model.TotalTrainers</text>
                            <text class="gauge-lbl" x="60" y="78" text-anchor="middle">Trainers</text>
                        </svg>
                    </div>
                </div>
            </div>
            <div class="gauges-grid mt-3">
                <div class="gauge-card gauge-sm">
                    <i class="bi bi-calendar-event gauge-icon" style="color:#00f0ff"></i>
                    <span class="gauge-num" style="color:#00f0ff">@Model.UpcomingSessions</span>
                    <span class="gauge-name">Upcoming Sessions</span>
                </div>
                <div class="gauge-card gauge-sm">
                    <i class="bi bi-play-circle gauge-icon" style="color:#7c3aed"></i>
                    <span class="gauge-num" style="color:#7c3aed">@Model.OngoingSessions</span>
                    <span class="gauge-name">Ongoing Sessions</span>
                </div>
                <div class="gauge-card gauge-sm">
                    <i class="bi bi-check-circle gauge-icon" style="color:#22c55e"></i>
                    <span class="gauge-num" style="color:#22c55e">@Model.CompletedSessions</span>
                    <span class="gauge-name">Completed Sessions</span>
                </div>
            </div>
        </div>
    }

    <!-- ── Interactive Ticker Bar ── -->
    <div class="ticker-bar">
        <div class="ticker-content justify-content-center">
            <span><i class="bi bi-star-fill text-neon me-1"></i> Personal Training</span>
            <span><i class="bi bi-star-fill text-neon me-1"></i> Live Classes</span>
            <span><i class="bi bi-star-fill text-neon me-1"></i> Certified Trainers</span>
            <span><i class="bi bi-star-fill text-neon me-1"></i> Outdoor Workouts</span>
            <span><i class="bi bi-star-fill text-neon me-1"></i> Gamified Badges</span>
        </div>
    </div>

</div>

@section Scripts {
    <script>
      (function() {
        document.querySelectorAll('.gauge-ring').forEach(function(el) {
          var val  = parseFloat(el.dataset.value) || 0;
          var max  = parseFloat(el.dataset.max)   || 100;
          var pct  = Math.min(val / max, 1);
          var fill = el.querySelector('.gauge-fill');
          if (fill) { setTimeout(function() { fill.style.setProperty('--pct', pct.toFixed(4)); }, 100); }
        });
      })();
    </script>
}