@using GymMangment.BLL.ViewModels.HealthRecordsViewModels
@model HealthRecordViewModel


@{
    var weightLabels = System.Text.Json.JsonSerializer.Serialize(Model.WeightProgress.Select(x => x.DateLabel));
    var weightValues = System.Text.Json.JsonSerializer.Serialize(Model.WeightProgress.Select(x => x.Weight));
}

<div class="container">
    <main role="main" class="pb-3">


        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="card shadow">
                        <div class="card-header bg-primary-color text-white text-center py-4">
                            <h3 class="mb-1">Health Record</h3>
                        </div>

                        <div class="card-body p-4">
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="card border-0 bg-light p-4 h-100">
                                        <div class="d-flex align-items-center mb-2">
                                            <div class="bg-primary-color rounded-circle p-2 me-3"
                                                 style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                <span class="text-white fw-bold">H</span>
                                            </div>
                                            <h6 class="text-muted mb-0">Height</h6>
                                        </div>
                                        <h4 class="text-primary-color mb-0">@Model.Height <small>cm</small></h4>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="card border-0 bg-light p-4 h-100">
                                        <div class="d-flex align-items-center mb-2">
                                            <div class="bg-primary-color rounded-circle p-2 me-3"
                                                 style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                <span class="text-white fw-bold">W</span>
                                            </div>
                                            <h6 class="text-muted mb-0">Weight</h6>
                                        </div>
                                        <h4 class="text-primary-color mb-0">@Model.Weight <small>kg</small></h4>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="card border-0 bg-light p-4 h-100">
                                        <div class="d-flex align-items-center mb-2">
                                            <div class="bg-danger rounded-circle p-2 me-3"
                                                 style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                <span class="text-white fw-bold">B</span>
                                            </div>
                                            <h6 class="text-muted mb-0">Blood Type</h6>
                                        </div>
                                        <h4 class="text-danger mb-0"> @Model.BloodType </h4>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="card border-0 bg-light p-4 h-100">
                                        <div class="d-flex align-items-center mb-2">
                                            <div class="bg-warning rounded-circle p-2 me-3"
                                                 style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                <span class="text-white fw-bold">N</span>
                                            </div>
                                            <h6 class="text-muted mb-0">Note</h6>
                                        </div>
                                        <h4 class="text-danger mb-0">@(Model.Note ?? "No notes added")</h4>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-5">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div>
                                        <h4 class="text-primary-color mb-1">Weight Progress</h4>
                                        <p class="text-muted mb-0">Last 6 months</p>
                                    </div>
                                    <span class="badge bg-primary-color">@Model.WeightProgress.Count() records</span>
                                </div>

                                @if (Model.WeightProgress.Any())
                                {
                                    <div style="height: 320px;">
                                        <canvas id="weightProgressChart"></canvas>
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center py-4 bg-light rounded">
                                        <i class="bi bi-graph-up display-6 text-muted"></i>
                                        <p class="text-muted mt-2 mb-0">No weight progress data for the last 6 months</p>
                                    </div>
                                }
                            </div>

                            <div class="card-footer bg-white border-0 p-4">
                                <div class="d-flex justify-content-between gap-2">
                                    <a asp-controller="Members" asp-action="Index" class="btn btn-fill flex-fill">
                                        Back to
                                        List
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </main>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const weightLabels = @Html.Raw(weightLabels);
        const weightValues = @Html.Raw(weightValues);
        const chartElement = document.getElementById('weightProgressChart');

        if (chartElement && weightLabels.length > 0) {
            new Chart(chartElement, {
                type: 'line',
                data: {
                    labels: weightLabels,
                    datasets: [{
                        label: 'Weight (kg)',
                        data: weightValues,
                        borderColor: '#0d6efd',
                        backgroundColor: 'rgba(13, 110, 253, 0.15)',
                        pointBackgroundColor: '#0d6efd',
                        pointBorderColor: '#ffffff',
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        tension: 0.35,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    return `${context.parsed.y} kg`;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: false,
                            title: {
                                display: true,
                                text: 'Weight (kg)'
                            }
                        },
                        x: {
                            title: {
                                display: true,
                                text: 'Date'
                            }
                        }
                    }
                }
            });
        }
    </script>
}
