@using GymMangment.BLL.ViewModels.HealthRecordsViewModels
@model HealthRecordViewModel


@{
    var weightLabels = System.Text.Json.JsonSerializer.Serialize(Model.WeightProgress.Select(x => x.DateLabel));
    var weightValues = System.Text.Json.JsonSerializer.Serialize(Model.WeightProgress.Select(x => x.Weight));

    decimal bmiVal = Model.BMI ?? 0;
    string progressWidth = "0%";
    string progressClass = "bg-secondary";
    if (bmiVal > 0)
    {
        if (bmiVal < 18.5m)
        {
            progressWidth = $"{Math.Max(5, Math.Min(25, ((bmiVal - 10) / 8.5m) * 25))}%";
            progressClass = "bg-info";
        }
        else if (bmiVal < 25.0m)
        {
            progressWidth = $"{25 + (((bmiVal - 18.5m) / 6.5m) * 25)}%";
            progressClass = "bg-success";
        }
        else if (bmiVal < 30.0m)
        {
            progressWidth = $"{50 + (((bmiVal - 25m) / 5m) * 25)}%";
            progressClass = "bg-warning";
        }
        else
        {
            progressWidth = $"{75 + Math.Min(25, (((bmiVal - 30m) / 15m) * 25))}%";
            progressClass = "bg-danger";
        }
    }

    string badgeClass = Model.BMICategory switch
    {
        "Underweight" => "bg-info text-dark",
        "Normal weight" => "bg-success text-white",
        "Overweight" => "bg-warning text-dark",
        "Obese" => "bg-danger text-white",
        _ => "bg-secondary"
    };

    string advice = Model.BMICategory switch
    {
        "Underweight" => "Focus on building lean muscle mass through strength training and a nutrient-dense, calorie-surplus diet. Consuming more healthy fats and proteins will help support healthy weight gain.",
        "Normal weight" => "Excellent! You are in a healthy BMI range. Maintain your current fitness level with a balanced mix of cardiovascular exercise, strength training, and a well-rounded diet.",
        "Overweight" => "You are in the overweight range. Incorporating a combination of calorie-burning cardio (like HIIT) and resistance training, along with a slight caloric deficit, can help you manage your weight.",
        "Obese" => "You are in the obese category. We recommend consulting a healthcare provider or a personal trainer to design a structured, low-impact exercise regimen (like swimming, cycling) and a tailored nutrition plan.",
        _ => "Provide height and weight to see recommendations."
    };
}

<div class="container mt-5">
    <div class="row g-4">
        <!-- Left Column: Health Record details + Weight Progress Chart -->
        <div class="col-lg-8">
            <div class="card shadow border-0">
                <div class="card-header bg-primary-color text-white text-center py-4">
                    <h3 class="mb-1">Health Record</h3>
                </div>

                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="card border-0 bg-light p-4 h-100">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="bg-primary-color rounded-circle p-2 me-3"
                                         style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                        <span class="text-white fw-bold">H</span>
                                    </div>
                                    <h6 class="text-muted mb-0">Height</h6>
                                </div>
                                <h4 class="text-primary-color mb-0">@Model.Height <small>cm</small></h4>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card border-0 bg-light p-4 h-100">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="bg-primary-color rounded-circle p-2 me-3"
                                         style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                        <span class="text-white fw-bold">W</span>
                                    </div>
                                    <h6 class="text-muted mb-0">Weight</h6>
                                </div>
                                <h4 class="text-primary-color mb-0">@Model.Weight <small>kg</small></h4>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card border-0 bg-light p-4 h-100">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="bg-danger rounded-circle p-2 me-3"
                                         style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                        <span class="text-white fw-bold">B</span>
                                    </div>
                                    <h6 class="text-muted mb-0">Blood Type</h6>
                                </div>
                                <h4 class="text-danger mb-0"> @Model.BloodType </h4>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card border-0 bg-light p-4 h-100">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="bg-warning rounded-circle p-2 me-3"
                                         style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                        <span class="text-white fw-bold">N</span>
                                    </div>
                                    <h6 class="text-muted mb-0">Note</h6>
                                </div>
                                <h4 class="text-danger mb-0">@(Model.Note ?? "No notes added")</h4>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <h4 class="text-primary-color mb-1">Weight Progress</h4>
                                <p class="text-muted mb-0">Last 6 months</p>
                            </div>
                            <span class="badge bg-primary-color">@Model.WeightProgress.Count() records</span>
                        </div>

                        @if (Model.WeightProgress.Any())
                        {
                            <div style="height: 320px;">
                                <canvas id="weightProgressChart"></canvas>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-4 bg-light rounded">
                                <i class="bi bi-graph-up display-6 text-muted"></i>
                                <p class="text-muted mt-2 mb-0">No weight progress data for the last 6 months</p>
                            </div>
                        }
                    </div>

                    <div class="card-footer bg-white border-0 p-4 mt-3">
                        <div class="d-flex justify-content-between gap-2">
                            <a asp-controller="Members" asp-action="Index" class="btn btn-fill flex-fill">
                                Back to List
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Server-Rendered BMI Dashboard Card -->
        <div class="col-lg-4">
            <div class="card shadow border-0 h-100 bg-light">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <h4 class="text-primary-color fw-bold mb-3">Health Dashboard</h4>
                        <p class="text-muted small">Body Mass Index (BMI) calculated based on member's latest height and weight details.</p>

                        <!-- BMI Display Box -->
                        <div class="text-center py-4 bg-white rounded-3 shadow-sm border mb-4">
                            <h6 class="text-muted mb-1 text-uppercase small fw-bold">Body Mass Index (BMI)</h6>
                            <div class="display-4 fw-bold text-primary-color my-2">
                                @(Model.BMI?.ToString("F1") ?? "--")
                            </div>
                            <span class="badge fs-6 px-3 py-2 rounded-pill @badgeClass">
                                @(Model.BMICategory ?? "No Data")
                            </span>
                        </div>

                        <!-- Progress Slider -->
                        <div class="mb-4">
                            <div class="d-flex justify-content-between small text-muted mb-1" style="font-size: 0.8rem;">
                                <span>Underweight</span>
                                <span>Normal</span>
                                <span>Overweight</span>
                                <span>Obese</span>
                            </div>
                            <div class="progress" style="height: 10px;">
                                <div class="progress-bar @progressClass" role="progressbar" style="width: @progressWidth;" aria-valuenow="@bmiVal" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                            <div class="d-flex justify-content-between small text-muted mt-1" style="font-size: 0.75rem;">
                                <span>&lt; 18.5</span>
                                <span>18.5 - 24.9</span>
                                <span>25.0 - 29.9</span>
                                <span>&gt;= 30.0</span>
                            </div>
                        </div>
                    </div>

                    <!-- Health Recommendation Section -->
                    <div class="bg-white p-3 rounded-3 border">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="bi bi-heart-pulse-fill text-danger fs-5"></i>
                            <h6 class="mb-0 fw-bold">Training Advice</h6>
                        </div>
                        <p class="text-muted small mb-0">
                            @advice
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

    </main>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const weightLabels = @Html.Raw(weightLabels);
        const weightValues = @Html.Raw(weightValues);
        const chartElement = document.getElementById('weightProgressChart');

        if (chartElement && weightLabels.length > 0) {
            new Chart(chartElement, {
                type: 'line',
                data: {
                    labels: weightLabels,
                    datasets: [{
                        label: 'Weight (kg)',
                        data: weightValues,
                        borderColor: '#0d6efd',
                        backgroundColor: 'rgba(13, 110, 253, 0.15)',
                        pointBackgroundColor: '#0d6efd',
                        pointBorderColor: '#ffffff',
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        tension: 0.35,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    return `${context.parsed.y} kg`;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: false,
                            title: {
                                display: true,
                                text: 'Weight (kg)'
                            }
                        },
                        x: {
                            title: {
                                display: true,
                                text: 'Date'
                            }
                        }
                    }
                }
            });
        }
    </script>
}
