@model IEnumerable<MemberViewModel>
@using GymMangment.BLL.ViewModels.MemberViewModels
@using GymManagment.DAL.Models.Enum
@{
    ViewData["Title"] = "Members";
}

<style>
/* ── Page Header ── */
.members-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:24px; flex-wrap:wrap; gap:12px; }
.page-heading { font-size:1.4rem; font-weight:800; color:#fff; letter-spacing:-0.5px; display:flex; align-items:center; gap:10px; margin:0; }
.page-heading i { color:#00f0ff; }
.count-badge { background:rgba(0,240,255,0.1); border:1px solid rgba(0,240,255,0.2); color:#00f0ff; font-size:0.7rem; font-weight:600; padding:3px 10px; border-radius:20px; letter-spacing:0.5px; }
.btn-add { display:inline-flex; align-items:center; gap:6px; background:linear-gradient(135deg,#7c3aed,#db2777); color:#fff; font-size:0.85rem; font-weight:600; padding:10px 20px; border-radius:12px; text-decoration:none; border:none; transition:all 0.3s; box-shadow:0 4px 16px rgba(124,58,237,0.35); }
.btn-add:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(124,58,237,0.5); color:#fff; }

/* ── Search Input ── */
.search-wrap { position:relative; margin-bottom:20px; }
.search-wrap i { position:absolute; left:14px; top:50%; transform:translateY(-50%); color:rgba(255,255,255,0.3); font-size:14px; }
#memberSearch { width:100%; max-width:340px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:10px 14px 10px 38px; color:#fff; font-size:0.85rem; outline:none; transition:border-color 0.3s; }
#memberSearch::placeholder { color:rgba(255,255,255,0.3); }
#memberSearch:focus { border-color:#00f0ff; }

/* ── Plan Chips with Distinct Colors ── */
.plan-chip { display:inline-flex; align-items:center; gap:5px; font-size:0.72rem; font-weight:700; padding:4px 12px; border-radius:20px; text-transform:capitalize; }
.plan-basic   { background:rgba(0,240,255,0.12); border:1px solid rgba(0,240,255,0.35); color:#00f0ff; }
.plan-premium { background:rgba(255,215,0,0.15); border:1px solid rgba(255,215,0,0.35); color:#ffd700; }
.plan-annual  { background:rgba(219,39,119,0.15); border:1px solid rgba(219,39,119,0.35); color:#f472b6; }
.plan-default { background:rgba(124,58,237,0.15); border:1px solid rgba(124,58,237,0.35); color:#a78bfa; }
.plan-chip.none { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); color:rgba(255,255,255,0.35); }

/* ── Gender Pills ── */
.gender-pill { font-size:0.7rem; font-weight:600; padding:3px 10px; border-radius:20px; }
.gender-m { background:rgba(14,165,233,0.15); color:#38bdf8; border:1px solid rgba(14,165,233,0.3); }
.gender-f { background:rgba(219,39,119,0.15); color:#f472b6; border:1px solid rgba(219,39,119,0.3); }
.gender-o { background:rgba(255,255,255,0.07); color:rgba(255,255,255,0.5); border:1px solid rgba(255,255,255,0.1); }

/* ── Desktop Glass Table ── */
.glass-table-wrap { background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.07); border-radius:20px; overflow:hidden; }
.glass-table { width:100%; border-collapse:collapse; }
.glass-table thead tr { border-bottom:1px solid rgba(255,255,255,0.07); }
.glass-table thead th { padding:14px 16px; font-size:0.65rem; font-weight:600; text-transform:uppercase; letter-spacing:1.2px; color:rgba(255,255,255,0.35); text-align:left; white-space:nowrap; }
.glass-table tbody tr { border-bottom:1px solid rgba(255,255,255,0.04); transition:background 0.2s; }
.glass-table tbody tr:last-child { border-bottom:none; }
.glass-table tbody tr:hover { background:rgba(255,255,255,0.04); }
.glass-table tbody td { padding:14px 16px; vertical-align:middle; font-size:0.85rem; color:rgba(255,255,255,0.8); }
.member-cell { display:flex; align-items:center; gap:12px; }
.member-avatar { width:42px; height:42px; border-radius:12px; object-fit:cover; flex-shrink:0; border:1px solid rgba(255,255,255,0.1); }
.avatar-fallback { width:42px; height:42px; border-radius:12px; background:linear-gradient(135deg,#7c3aed,#db2777); display:flex; align-items:center; justify-content:center; font-size:0.9rem; font-weight:700; color:#fff; flex-shrink:0; }
.member-name { font-weight:600; color:#fff; font-size:0.88rem; }
.member-email { font-size:0.73rem; color:rgba(255,255,255,0.4); margin-top:1px; }

.action-btn { background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); border-radius:8px; color:rgba(255,255,255,0.6); padding:6px 10px; cursor:pointer; transition:all 0.2s; font-size:1rem; }
.action-btn:hover { background:rgba(255,255,255,0.12); color:#fff; }

.dropdown-menu-dark-glass { background:rgba(15,12,30,0.95) !important; backdrop-filter:blur(20px) !important; border:1px solid rgba(255,255,255,0.1) !important; border-radius:14px !important; padding:6px !important; min-width:200px !important; box-shadow:0 16px 40px rgba(0,0,0,0.5) !important; }
.dropdown-menu-dark-glass .dropdown-item { border-radius:8px !important; padding:9px 14px !important; color:rgba(255,255,255,0.7) !important; font-size:0.82rem !important; display:flex; align-items:center; gap:8px; transition:background 0.2s; }
.dropdown-menu-dark-glass .dropdown-item:hover { background:rgba(255,255,255,0.08) !important; color:#fff !important; }
.dropdown-menu-dark-glass .dropdown-item.text-danger { color:#f87171 !important; }
.dropdown-menu-dark-glass .dropdown-divider { border-color:rgba(255,255,255,0.08) !important; margin:4px 0 !important; }

/* ── Mobile Member Cards Grid ── */
.mobile-cards-grid { display:none; }
.member-mobile-card {
    background:rgba(255,255,255,0.03);
    border:1px solid rgba(255,255,255,0.08);
    backdrop-filter:blur(16px);
    border-radius:20px;
    padding:20px;
    margin-bottom:14px;
    position: relative;
    z-index: 1;
}
.member-mobile-card:has(.dropdown-menu.show) {
    z-index: 15 !important;
}
.mobile-card-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
.mobile-card-info { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:10px; padding-top:10px; border-top:1px solid rgba(255,255,255,0.06); }
.mobile-info-label { font-size:0.62rem; text-transform:uppercase; letter-spacing:1px; color:rgba(255,255,255,0.35); margin-bottom:2px; display:block; }
.mobile-info-val { font-size:0.82rem; color:rgba(255,255,255,0.8); }
.mobile-card-footer { display:flex; justify-content:flex-end; padding-top:12px; margin-top:12px; border-top:1px solid rgba(255,255,255,0.06); }
.btn-card-action { display:inline-flex; align-items:center; justify-content:center; width:38px; height:38px; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); color:rgba(255,255,255,0.8); font-size:1.1rem; border-radius:50%; cursor:pointer; transition:all 0.3s cubic-bezier(0.16,1,0.3,1); box-shadow:0 4px 10px rgba(0,0,0,0.15); }
.btn-card-action:hover { background:linear-gradient(135deg,rgba(124,58,237,0.25),rgba(219,39,119,0.15)); border-color:rgba(124,58,237,0.35); color:#fff; box-shadow:0 0 12px rgba(124,58,237,0.25); transform:translateY(-2px); }
.btn-card-action:active { transform:translateY(0); }

.empty-state { text-align:center; padding:60px 24px; color:rgba(255,255,255,0.3); }
.empty-state i { font-size:3rem; margin-bottom:12px; display:block; }
.empty-state h4 { font-size:1rem; font-weight:600; color:rgba(255,255,255,0.5); }
.empty-state p { font-size:0.82rem; margin-top:4px; }

/* ── Responsive View Switching ── */
@@media (max-width:768px) {
    #memberSearch { max-width:100%; }
    .glass-table-wrap { display:none; }
    .mobile-cards-grid { display:block; }
}
</style>

<div class="members-header">
    <h1 class="page-heading">
        <i class="bi bi-people-fill"></i>
        Members
        <span class="count-badge">@Model.Count() total</span>
    </h1>
    <a asp-controller="Members" asp-action="Create" class="btn-add">
        <i class="bi bi-person-plus-fill"></i> Add Member
    </a>
</div>

<div class="search-wrap">
    <i class="bi bi-search"></i>
    <input type="text" id="memberSearch" placeholder="Search by name, email or phone..." autocomplete="off" />
</div>

@if (Model.Any())
{
    <!-- Desktop Table View -->
    <div class="glass-table-wrap">
        <table class="glass-table" id="membersTable">
            <thead>
                <tr>
                    <th>Member</th>
                    <th>Phone</th>
                    <th>Gender</th>
                    <th>Plan</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var member in Model)
                {
                    var initials = member.Name.Length > 0 ? member.Name[0].ToString().ToUpper() : "?";
                    var gClass = (member.Gender ?? "").ToLower() switch {
                        "male"   => "gender-m",
                        "female" => "gender-f",
                        _        => "gender-o"
                    };

                    var pName = (member.PlanName ?? "").ToLower();
                    var planClass = pName switch {
                        var p when p.Contains("basic") || p.Contains("silver") => "plan-basic",
                        var p when p.Contains("premium") || p.Contains("gold") || p.Contains("vip") => "plan-premium",
                        var p when p.Contains("annual") || p.Contains("platinum") || p.Contains("pro") => "plan-annual",
                        _ when !string.IsNullOrEmpty(member.PlanName) => "plan-default",
                        _ => "none"
                    };

                    <tr class="member-row">
                        <td>
                            <div class="member-cell">
                                @if (!string.IsNullOrEmpty(member.photo))
                                {
                                    <img src="@member.photo" alt="@member.Name" class="member-avatar" />
                                }
                                else
                                {
                                    <div class="avatar-fallback">@initials</div>
                                }
                                <div>
                                    <div class="member-name">@member.Name</div>
                                    <div class="member-email">@member.Email</div>
                                </div>
                            </div>
                        </td>
                        <td style="color:rgba(255,255,255,0.55);">@member.Phone</td>
                        <td><span class="gender-pill @gClass">@member.Gender</span></td>
                        <td>
                            @if (!string.IsNullOrEmpty(member.PlanName))
                            {
                                <span class="plan-chip @planClass"><i class="bi bi-star-fill" style="font-size:0.6rem;"></i> @member.PlanName</span>
                            }
                            else
                            {
                                <span class="plan-chip none">No plan</span>
                            }
                        </td>
                        <td>
                            <div class="dropdown">
                                <button class="action-btn" type="button" id="drop-@member.Id" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-three-dots"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark-glass" aria-labelledby="drop-@member.Id">
                                    <li><a asp-controller="Members" asp-action="MemberDetails" asp-route-id="@member.Id" class="dropdown-item"><i class="bi bi-eye" style="color:#00f0ff;"></i> View Details</a></li>
                                    <li><a asp-controller="Members" asp-action="HealthRecordDetails" asp-route-id="@member.Id" class="dropdown-item"><i class="bi bi-heart-pulse" style="color:#f472b6;"></i> Health Record</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a asp-controller="Members" asp-action="EditMember" asp-route-id="@member.Id" class="dropdown-item"><i class="bi bi-pencil" style="color:#a78bfa;"></i> Edit</a></li>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a asp-controller="Members" asp-action="Delete" asp-route-id="@member.Id" class="dropdown-item text-danger"><i class="bi bi-trash3"></i> Delete</a></li>
                                    }
                                    else if (User.IsInRole("Manager"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form asp-controller="DeleteRequests" asp-action="SubmitRequest" method="post" class="delete-request-form">
                                                <input type="hidden" name="targetType" value="@DeleteTargetType.Member" />
                                                <input type="hidden" name="targetId" value="@member.Id" />
                                                <button type="submit" class="dropdown-item text-danger"><i class="bi bi-flag"></i> Request Delete</button>
                                            </form>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Mobile Card View -->
    <div class="mobile-cards-grid">
        @foreach (var member in Model)
        {
            var initials = member.Name.Length > 0 ? member.Name[0].ToString().ToUpper() : "?";
            var gClass = (member.Gender ?? "").ToLower() switch {
                "male"   => "gender-m",
                "female" => "gender-f",
                _        => "gender-o"
            };

            var pName = (member.PlanName ?? "").ToLower();
            var planClass = pName switch {
                var p when p.Contains("basic") || p.Contains("silver") => "plan-basic",
                var p when p.Contains("premium") || p.Contains("gold") || p.Contains("vip") => "plan-premium",
                var p when p.Contains("annual") || p.Contains("platinum") || p.Contains("pro") => "plan-annual",
                _ when !string.IsNullOrEmpty(member.PlanName) => "plan-default",
                _ => "none"
            };

            <div class="member-mobile-card">
                <div class="mobile-card-header">
                    <div class="member-cell">
                        @if (!string.IsNullOrEmpty(member.photo))
                        {
                            <img src="@member.photo" alt="@member.Name" class="member-avatar" />
                        }
                        else
                        {
                            <div class="avatar-fallback">@initials</div>
                        }
                        <div>
                            <div class="member-name">@member.Name</div>
                            <div class="member-email">@member.Email</div>
                        </div>
                    </div>
                </div>

                <div class="mobile-card-info">
                    <div>
                        <span class="mobile-info-label">Phone</span>
                        <div class="mobile-info-val">@member.Phone</div>
                    </div>
                    <div>
                        <span class="mobile-info-label">Gender</span>
                        <div><span class="gender-pill @gClass">@member.Gender</span></div>
                    </div>
                    <div style="grid-column: span 2;">
                        <span class="mobile-info-label">Current Plan</span>
                        <div>
                            @if (!string.IsNullOrEmpty(member.PlanName))
                            {
                                <span class="plan-chip @planClass"><i class="bi bi-star-fill" style="font-size:0.6rem;"></i> @member.PlanName</span>
                            }
                            else
                            {
                                <span class="plan-chip none">No plan</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="mobile-card-footer">
                    <div class="dropdown">
                        <button class="btn-card-action" type="button" id="drop-mob-@member.Id" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-three-dots-vertical"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark-glass" aria-labelledby="drop-mob-@member.Id">
                            <li><a asp-controller="Members" asp-action="MemberDetails" asp-route-id="@member.Id" class="dropdown-item"><i class="bi bi-eye" style="color:#00f0ff;"></i> View Details</a></li>
                            <li><a asp-controller="Members" asp-action="HealthRecordDetails" asp-route-id="@member.Id" class="dropdown-item"><i class="bi bi-heart-pulse" style="color:#f472b6;"></i> Health Record</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a asp-controller="Members" asp-action="EditMember" asp-route-id="@member.Id" class="dropdown-item"><i class="bi bi-pencil" style="color:#a78bfa;"></i> Edit</a></li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li><hr class="dropdown-divider"></li>
                                <li><a asp-controller="Members" asp-action="Delete" asp-route-id="@member.Id" class="dropdown-item text-danger"><i class="bi bi-trash3"></i> Delete</a></li>
                            }
                            else if (User.IsInRole("Manager"))
                            {
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="DeleteRequests" asp-action="SubmitRequest" method="post" class="delete-request-form">
                                        <input type="hidden" name="targetType" value="@DeleteTargetType.Member" />
                                        <input type="hidden" name="targetId" value="@member.Id" />
                                        <button type="submit" class="dropdown-item text-danger"><i class="bi bi-flag"></i> Request Delete</button>
                                    </form>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="glass-table-wrap">
        <div class="empty-state">
            <i class="bi bi-person-workspace"></i>
            <h4>No Members Yet</h4>
            <p>Add your first member to get started.</p>
        </div>
    </div>
}

@section Scripts {
    <partial name="_AlertboxScript" />
    <script>
        document.getElementById('memberSearch').addEventListener('input', function() {
            var q = this.value.toLowerCase();
            document.querySelectorAll('.member-row, .member-mobile-card').forEach(function(el) {
                el.style.display = el.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        });
    </script>
}