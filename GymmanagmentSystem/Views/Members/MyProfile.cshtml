@using GymMangment.BLL.ViewModels.MemberViewModels
@model MemberToUpdateViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="container mt-4">
    <header class="mb-4">
        <h3 class="text-primary-color">My Profile</h3>
        <p class="text-muted">Update your personal information</p>
    </header>

    <div class="row g-4">
        <!-- Left Column: Profile form -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body p-4">
                    <div class="mb-4 pb-3 border-bottom d-flex align-items-center gap-3">
                        @if (!string.IsNullOrEmpty(Model.CurrentPhoto))
                        {
                            <img src="@Model.CurrentPhoto" class="rounded-circle"
                                 style="width:80px;height:80px;object-fit:cover;" />
                        }
                        else
                        {
                            <img src="~/images/User.jpg" class="rounded-circle"
                                 style="width:80px;height:80px;object-fit:cover;" />
                        }
                        <div>
                            <small class="text-muted d-block mb-1">Profile For</small>
                            <h4 class="mb-0 text-black">@Model.Name</h4>
                        </div>
                    </div>

                    <form asp-controller="Members" asp-action="MyProfile" method="post"
                          enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="Name" />

                        <!-- Personal Information -->
                        <div class="section-header mb-3">
                            <h5 class="text-primary fw-bold">Personal Information</h5>
                            <hr class="mt-2">
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                                <input asp-for="Email" type="email" class="form-control" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Phone" class="form-label fw-semibold">Phone <span class="text-danger">*</span></label>
                                <input asp-for="Phone" class="form-control" />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="BuildingNumber" class="form-label fw-semibold">Building No. <span class="text-danger">*</span></label>
                                <input asp-for="BuildingNumber" class="form-control" />
                                <span asp-validation-for="BuildingNumber" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="City" class="form-label fw-semibold">City <span class="text-danger">*</span></label>
                                <input asp-for="City" class="form-control" />
                                <span asp-validation-for="City" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Street" class="form-label fw-semibold">Street <span class="text-danger">*</span></label>
                                <input asp-for="Street" class="form-control" />
                                <span asp-validation-for="Street" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Photo" class="form-label fw-semibold">Update Photo</label>
                                <input asp-for="Photo" type="file" class="form-control"
                                       accept=".jpg,.jpeg,.png,.webp" />
                                <small class="text-muted">Optional. Max 2MB. JPG, PNG or WebP.</small>
                            </div>
                        </div>

                        <!-- Health Record -->
                        <div class="section-header mb-3 mt-4">
                            <h5 class="text-primary fw-bold">Health Record</h5>
                            <hr class="mt-2">
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Height" class="form-label fw-semibold">Height (cm)</label>
                                <input asp-for="Height" type="number" step="0.1" class="form-control" />
                                <span asp-validation-for="Height" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Weight" class="form-label fw-semibold">Weight (kg)</label>
                                <input asp-for="Weight" type="number" step="0.1" class="form-control" />
                                <span asp-validation-for="Weight" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="BloodType" class="form-label fw-semibold">Blood Type</label>
                                <select asp-for="BloodType" class="form-select">
                                    <option value="">Select</option>
                                    <option>A+</option>
                                    <option>A-</option>
                                    <option>B+</option>
                                    <option>B-</option>
                                    <option>O+</option>
                                    <option>O-</option>
                                    <option>AB+</option>
                                    <option>AB-</option>
                                </select>
                                <span asp-validation-for="BloodType" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Note" class="form-label fw-semibold">Notes</label>
                                <input asp-for="Note" class="form-control" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                            <button type="submit" class="btn btn-primary" id="saveBtn"
                                    onclick="showLoading(this)">
                                <span class="spinner-border spinner-border-sm d-none" id="spinner" role="status" aria-hidden="true"></span>
                                <span id="btnText">Save Changes</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Right Column: Interactive BMI Dashboard & Badges -->
        <div class="col-lg-4">
            <!-- Health Card -->
            <div class="card shadow-sm border-0 bg-light mb-4">
                <div class="card-body p-4">
                    <h4 class="text-primary-color fw-bold mb-3">Health Dashboard</h4>
                    <p class="text-muted small">Your Body Mass Index (BMI) is calculated in real-time based on your weight and height.</p>

                    <!-- BMI Display Box -->
                    <div class="text-center py-4 bg-white rounded-3 shadow-sm border mb-4">
                        <h6 class="text-muted mb-1 text-uppercase small fw-bold">Body Mass Index (BMI)</h6>
                        <div class="display-4 fw-bold text-primary-color my-2" id="bmiScore">
                            @(Model.BMI?.ToString("F1") ?? "--")
                        </div>
                        <span class="badge fs-6 px-3 py-2 rounded-pill" id="bmiCategoryBadge">
                            @(Model.BMICategory ?? "No Data")
                        </span>
                    </div>

                    <!-- Progress Slider -->
                    <div class="mb-4">
                        <div class="d-flex justify-content-between small text-muted mb-1" style="font-size: 0.8rem;">
                            <span>Underweight</span>
                            <span>Normal</span>
                            <span>Overweight</span>
                            <span>Obese</span>
                        </div>
                        <div class="progress" style="height: 10px;">
                            <div id="bmiProgressBar" class="progress-bar" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <div class="d-flex justify-content-between small text-muted mt-1" style="font-size: 0.75rem;">
                            <span>&lt; 18.5</span>
                            <span>18.5 - 24.9</span>
                            <span>25.0 - 29.9</span>
                            <span>&gt;= 30.0</span>
                        </div>
                    </div>

                    <!-- Health Recommendation Section -->
                    <div class="bg-white p-3 rounded-3 border">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="bi bi-heart-pulse-fill text-danger fs-5"></i>
                            <h6 class="mb-0 fw-bold">Training Advice</h6>
                        </div>
                        <p class="text-muted small mb-0" id="bmiRecommendation">
                            Provide your height and weight to receive a fitness recommendation.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Achievements Card -->
            <div class="card shadow-sm border-0 bg-light">
                <div class="card-body p-4">
                    <h4 class="text-primary-color fw-bold mb-3">My Achievements</h4>
                    <p class="text-muted small">Your recently unlocked fitness badges.</p>

                    @if (ViewBag.EarnedBadges == null || !((List<GymMangment.BLL.ViewModels.BadgeViewModels.MemberBadgeViewModel>)ViewBag.EarnedBadges).Any())
                    {
                        <div class="text-center py-4 bg-white rounded-3 border">
                            <i class="bi bi-trophy text-muted display-6 mb-2 d-block"></i>
                            <p class="text-muted small mb-0">No badges earned yet.</p>
                        </div>
                    }
                    else
                    {
                        <div class="bg-white p-3 rounded-3 border mb-3">
                            <div class="d-flex flex-wrap gap-2 justify-content-center">
                                @foreach (var badge in ((List<GymMangment.BLL.ViewModels.BadgeViewModels.MemberBadgeViewModel>)ViewBag.EarnedBadges).Take(4))
                                {
                                    <div class="text-center" style="width: 60px;" title="@badge.BadgeName - @badge.BadgeDescription">
                                        <img src="@badge.BadgeIconPath" class="rounded-circle border border-2 border-warning shadow-sm" style="width: 40px; height: 40px; object-fit: cover;" />
                                        <span class="d-block text-truncate fw-semibold text-dark mt-1" style="font-size: 8px;">@badge.BadgeName</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    <div class="text-center">
                        <a href="/Achievements/MyAchievements" class="btn btn-outline-primary btn-sm rounded-pill w-100 fw-bold text-decoration-none">
                            View All Achievements <i class="bi bi-arrow-right-short ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelector('input[type="file"]').addEventListener('change', function(e) {
            if (e.target.files && e.target.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    document.querySelector('.rounded-circle').src = e.target.result;
                }
                reader.readAsDataURL(e.target.files[0]);
            }
        });
    </script>
    <script>
        function showLoading(btn) {
            document.getElementById('btnText').innerText = 'Saving...';
            document.getElementById('spinner').classList.remove('d-none');
            btn.disabled = true;
            btn.form.submit();
        }
    </script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const heightInput = document.getElementById("Height");
            const weightInput = document.getElementById("Weight");
            const bmiScore = document.getElementById("bmiScore");
            const bmiCategoryBadge = document.getElementById("bmiCategoryBadge");
            const bmiProgressBar = document.getElementById("bmiProgressBar");
            const bmiRecommendation = document.getElementById("bmiRecommendation");

            function calculateBMI() {
                const height = parseFloat(heightInput.value);
                const weight = parseFloat(weightInput.value);

                if (isNaN(height) || isNaN(weight) || height <= 0 || weight <= 0) {
                    bmiScore.innerText = "--";
                    bmiCategoryBadge.innerText = "No Data";
                    bmiCategoryBadge.className = "badge bg-secondary fs-6 px-3 py-2 rounded-pill";
                    bmiProgressBar.style.width = "0%";
                    bmiProgressBar.className = "progress-bar bg-secondary";
                    bmiRecommendation.innerText = "Please enter valid height and weight values to get your BMI calculation.";
                    return;
                }

                // Convert height from cm to meters
                const heightInMeters = height / 100;
                const bmi = weight / (heightInMeters * heightInMeters);
                const bmiRounded = bmi.toFixed(1);

                bmiScore.innerText = bmiRounded;

                let category = "";
                let badgeClass = "";
                let progressWidth = 0;
                let progressClass = "";
                let recommendation = "";

                if (bmi < 18.5) {
                    category = "Underweight";
                    badgeClass = "bg-info text-dark";
                    progressWidth = Math.max(5, Math.min(25, ((bmi - 10) / 8.5) * 25));
                    progressClass = "bg-info";
                    recommendation = "Focus on building lean muscle mass through strength training and a nutrient-dense, calorie-surplus diet. Consuming more healthy fats and proteins will help support healthy weight gain.";
                } else if (bmi < 25.0) {
                    category = "Normal Weight";
                    badgeClass = "bg-success text-white";
                    progressWidth = 25 + (((bmi - 18.5) / 6.5) * 25);
                    progressClass = "bg-success";
                    recommendation = "Excellent! You are in a healthy BMI range. Maintain your current fitness level with a balanced mix of cardiovascular exercise, strength training, and a well-rounded diet.";
                } else if (bmi < 30.0) {
                    category = "Overweight";
                    badgeClass = "bg-warning text-dark";
                    progressWidth = 50 + (((bmi - 25) / 5) * 25);
                    progressClass = "bg-warning";
                    recommendation = "You are in the overweight range. Incorporating a combination of calorie-burning cardio (like HIIT) and resistance training, along with a slight caloric deficit, can help you manage your weight.";
                } else {
                    category = "Obese";
                    badgeClass = "bg-danger text-white";
                    progressWidth = 75 + Math.min(25, (((bmi - 30) / 15) * 25));
                    progressClass = "bg-danger";
                    recommendation = "You are in the obese category. We recommend consulting a healthcare provider or a personal trainer to design a structured, low-impact exercise regimen (like swimming, cycling) and a tailored nutrition plan.";
                }

                bmiCategoryBadge.innerText = category;
                bmiCategoryBadge.className = `badge ${badgeClass} fs-6 px-3 py-2 rounded-pill`;
                bmiProgressBar.style.width = `${progressWidth}%`;
                bmiProgressBar.className = `progress-bar ${progressClass}`;
                bmiRecommendation.innerText = recommendation;
            }

            heightInput.addEventListener("input", calculateBMI);
            weightInput.addEventListener("input", calculateBMI);

            // Run initial calculation
            calculateBMI();
        });
    </script>
}