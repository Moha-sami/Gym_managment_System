@model MemberToUpdateViewModel

<style>
    /* ===== MOBILE (up to 767px) ===== */
    @@media (max-width: 767.98px) {
        /* Card adjustments */
        .card-details {
            margin: 0 0.25rem !important;
            padding: 0.5rem !important;
            border-radius: 16px !important;
        }
            /* Avatar - smaller on mobile, centered */
            .card-details .avatar-wrapper {
                display: flex !important;
                justify-content: center !important;
                align-items: center !important;
                padding-top: 0 !important;
                padding-bottom: 0.25rem !important;
            }

                .card-details .avatar-wrapper img {
                    width: 60px !important;
                    height: 60px !important;
                    border-radius: 50% !important;
                    object-fit: cover !important;
                    border: 3px solid #fff !important;
                    box-shadow: 0 2px 8px rgba(0,0,0,0.1) !important;
                    margin-top: 0 !important;
                }
            /* Name - blue color matching button, ONE line */
            .card-details .card-body h2 {
                font-size: 1.1rem !important;
                color: #0d6efd !important;
                text-align: center !important;
                margin-top: 0 !important;
                margin-bottom: 0.15rem !important;
                white-space: nowrap !important;
                overflow: visible !important;
            }
            /* Each info row - full width (stack vertically) */
            .card-details .row .col-6 {
                flex: 0 0 100% !important;
                max-width: 100% !important;
            }
            /* Info boxes - full width */
            .card-details .row .col-12,
            .card-details .row .col-6 {
                padding-left: 0 !important;
                padding-right: 0 !important;
            }
            /* Info box - centered text, label on top, input below */
            .card-details .p-3 {
                padding: 0.4rem 0.5rem !important;
                text-align: center !important;
                display: flex !important;
                flex-direction: column !important;
                align-items: center !important;
            }
            /* Labels - on top, centered, ONE line */
            .card-details small.text-muted {
                font-size: 0.55rem !important;
                display: block !important;
                text-align: center !important;
                margin-bottom: 0.15rem !important;
                text-transform: uppercase !important;
                letter-spacing: 0.5px !important;
                white-space: nowrap !important;
                overflow: visible !important;
                width: 100% !important;
            }
            /* Form inputs - centered, full width */
            .card-details .form-control {
                font-size: 0.8rem !important;
                padding: 0.4rem 0.5rem !important;
                text-align: center !important;
                width: 100% !important;
                border-radius: 8px !important;
                border: 1px solid #ced4da !important;
            }
            /* Validation errors - centered */
            .card-details .text-danger {
                font-size: 0.65rem !important;
                text-align: center !important;
                display: block !important;
                width: 100% !important;
            }
            /* Buttons - full width, stacked */
            .card-details .d-flex {
                flex-direction: column !important;
                gap: 0.5rem !important;
                padding: 0 0.5rem 0.5rem 0.5rem !important;
            }

                .card-details .d-flex .btn {
                    width: 100% !important;
                    text-align: center !important;
                    font-size: 0.85rem !important;
                    padding: 0.5rem !important;
                    border-radius: 50px !important;
                    background: #0d6efd !important;
                    color: white !important;
                    border: none !important;
                    transition: all 0.3s ease !important;
                    font-weight: 500 !important;
                }

                    .card-details .d-flex .btn:hover {
                        background: #0b5ed7 !important;
                        color: white !important;
                        transform: translateY(-2px) !important;
                        box-shadow: 0 4px 12px rgba(13, 110, 253, 0.35) !important;
                    }

                .card-details .d-flex .btn-fill {
                    background: #0d6efd !important;
                    color: white !important;
                }
        /* Prevent any horizontal scroll */
        body, html {
            overflow-x: hidden !important;
            max-width: 100% !important;
        }

        .container {
            overflow-x: hidden !important;
            max-width: 100% !important;
            padding-left: 8px !important;
            padding-right: 8px !important;
        }

        .row {
            margin-left: 0 !important;
            margin-right: 0 !important;
        }

        .col-md-6 {
            padding-left: 0 !important;
            padding-right: 0 !important;
        }

        .justify-content-center {
            margin-left: 0 !important;
            margin-right: 0 !important;
        }
    }

    /* ===== TABLET (768px - 991px) ===== */
    @@media (min-width: 768px) and (max-width: 991.98px) {
        .card-details .row .col-6 {
            flex: 0 0 50% !important;
            max-width: 50% !important;
        }

        .card-details .p-3 {
            padding: 0.5rem 0.75rem !important;
        }

        .card-details .form-control {
            font-size: 0.85rem !important;
        }

        .card-details small.text-muted {
            font-size: 0.6rem !important;
            white-space: nowrap !important;
        }

        .card-details .avatar-wrapper img {
            width: 80px !important;
            height: 80px !important;
        }

        .card-details .card-body h2 {
            font-size: 1.3rem !important;
            color: #0d6efd !important;
        }

        .card-details .d-flex .btn {
            font-size: 0.9rem !important;
            padding: 0.5rem 1.5rem !important;
        }
    }

    /* ===== LAPTOP (992px+) ===== */
    @@media (min-width: 992px) {
        .card-details .row .col-6 {
            flex: 0 0 50% !important;
            max-width: 50% !important;
        }

        .card-details .avatar-wrapper img {
            width: 120px !important;
            height: 120px !important;
            margin-top: 0 !important;
        }

        .card-details .card-body h2 {
            color: #0d6efd !important;
        }

        .card-details .btn-fill {
            background: #0d6efd !important;
            color: white !important;
            border-radius: 50px !important;
            border: none !important;
            transition: all 0.3s ease !important;
            font-weight: 500 !important;
            padding: 0.6rem 1.5rem !important;
        }

            .card-details .btn-fill:hover {
                background: #0b5ed7 !important;
                color: white !important;
                transform: translateY(-2px) !important;
                box-shadow: 0 4px 12px rgba(13, 110, 253, 0.35) !important;
            }
    }

    /* ===== COMMON STYLES ===== */
    .card-details {
        border-radius: 16px !important;
        overflow: visible !important;
        background: white !important;
    }

        .card-details .bg-light {
            background-color: #f8f9fa !important;
            border-radius: 8px !important;
        }

        .card-details .avatar-wrapper {
            display: flex !important;
            justify-content: center !important;
        }

        .card-details .form-control:focus {
            border-color: #0d6efd !important;
            box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25) !important;
        }

    /* Button style matching Add Member - applies to all screen sizes */
    .btn-fill {
        background: #0d6efd !important;
        color: white !important;
        border-radius: 50px !important;
        border: none !important;
        transition: all 0.3s ease !important;
        font-weight: 500 !important;
        padding: 0.6rem 1.5rem !important;
        font-size: 1rem !important;
    }

        .btn-fill:hover {
            background: #0b5ed7 !important;
            color: white !important;
            transform: translateY(-2px) !important;
            box-shadow: 0 4px 12px rgba(13, 110, 253, 0.35) !important;
        }
</style>

<div class="container mt-4">
    <header class="mb-4">
        <h3 class="text-primary-color">My Profile</h3>
        <p class="text-muted">Update your personal information</p>
    </header>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="mb-4 pb-3 border-bottom d-flex align-items-center gap-3">
                        @if (!string.IsNullOrEmpty(Model.CurrentPhoto))
                        {
                            <img src="@Model.CurrentPhoto" class="rounded-circle"
                                 style="width:80px;height:80px;object-fit:cover;" />
                        }
                        else
                        {
                            <img src="~/images/User.jpg" class="rounded-circle"
                                 style="width:80px;height:80px;object-fit:cover;" />
                        }
                        <div>
                            <small class="text-muted d-block mb-1">Profile For</small>
                            <h4 class="mb-0 text-black">@Model.Name</h4>
                        </div>
                    </div>

                    <form asp-controller="Members" asp-action="MyProfile" method="post"
                          enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="Name" />

                        <!-- Personal Information -->
                        <div class="section-header mb-3">
                            <h5 class="text-primary fw-bold">Personal Information</h5>
                            <hr class="mt-2">
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                                <input asp-for="Email" type="email" class="form-control" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Phone" class="form-label fw-semibold">Phone <span class="text-danger">*</span></label>
                                <input asp-for="Phone" class="form-control" />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="BuildingNumber" class="form-label fw-semibold">Building No. <span class="text-danger">*</span></label>
                                <input asp-for="BuildingNumber" class="form-control" />
                                <span asp-validation-for="BuildingNumber" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="City" class="form-label fw-semibold">City <span class="text-danger">*</span></label>
                                <input asp-for="City" class="form-control" />
                                <span asp-validation-for="City" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Street" class="form-label fw-semibold">Street <span class="text-danger">*</span></label>
                                <input asp-for="Street" class="form-control" />
                                <span asp-validation-for="Street" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Photo" class="form-label fw-semibold">Update Photo</label>
                                <input asp-for="Photo" type="file" class="form-control"
                                       accept=".jpg,.jpeg,.png,.webp" />
                                <small class="text-muted">Optional. Max 2MB. JPG, PNG or WebP.</small>
                            </div>
                        </div>

                        <!-- Health Record -->
                        <div class="section-header mb-3 mt-4">
                            <h5 class="text-primary fw-bold">Health Record</h5>
                            <hr class="mt-2">
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Height" class="form-label fw-semibold">Height (cm)</label>
                                <input asp-for="Height" type="number" step="0.1" class="form-control" />
                                <span asp-validation-for="Height" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Weight" class="form-label fw-semibold">Weight (kg)</label>
                                <input asp-for="Weight" type="number" step="0.1" class="form-control" />
                                <span asp-validation-for="Weight" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="BloodType" class="form-label fw-semibold">Blood Type</label>
                                <select asp-for="BloodType" class="form-select">
                                    <option value="">Select</option>
                                    <option>A+</option>
                                    <option>A-</option>
                                    <option>B+</option>
                                    <option>B-</option>
                                    <option>O+</option>
                                    <option>O-</option>
                                    <option>AB+</option>
                                    <option>AB-</option>
                                </select>
                                <span asp-validation-for="BloodType" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Note" class="form-label fw-semibold">Notes</label>
                                <input asp-for="Note" class="form-control" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                            <button type="submit" class="btn btn-fill">
                                <i class="bi bi-check-lg me-1"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}