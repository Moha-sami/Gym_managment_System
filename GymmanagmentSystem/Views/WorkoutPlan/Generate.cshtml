@using GymMangment.BLL.ViewModels.WorkoutPlanViewModels
@model GeneratePlanRequestViewModel
@{
    ViewData["Title"] = "Generate Workout Plan";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-primary text-white py-3 text-center rounded-top-3" style="background: linear-gradient(135deg, #0a1172 0%, #2d3fdb 100%) !important;">
                    <h3 class="card-title mb-0 fw-bold">
                        <i class="bi bi-magic me-2"></i>Workout Plan Generator
                    </h3>
                    <p class="mb-0 text-white-50 mt-1 small">Answer a few questions to get your expert workout routine</p>
                </div>
                <div class="card-body p-4 p-md-5">
                    @if (ViewBag.HasActivePlan == true)
                    {
                        <div class="alert alert-warning mb-4 text-center d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                            <span>You already have an active plan. Generating a new one will replace your current plan.</span>
                        </div>
                    }

                    <form asp-controller="WorkoutPlan" asp-action="Generate" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <!-- Goal -->
                        <div class="mb-4">
                            <label asp-for="Goal" class="form-label fw-bold text-dark mb-2">What is your main fitness goal?</label>
                            <div class="row g-3">
                                <div class="col-12">
                                    <input type="radio" class="btn-check" asp-for="Goal" value="Build Muscle" id="goalMuscle" checked />
                                    <label class="btn btn-outline-primary w-100 p-3 text-start rounded-3" for="goalMuscle">
                                        <div class="d-flex align-items-center">
                                            <div class="icon-box bg-primary-subtle text-primary rounded-circle p-2 me-3">
                                                <i class="bi bi-fire fs-4"></i>
                                            </div>
                                            <div>
                                                <strong class="d-block text-dark">Build Muscle & Strength</strong>
                                                <span class="text-muted small">Hypertrophy-focused training for mass and power</span>
                                            </div>
                                        </div>
                                    </label>
                                </div>

                                <div class="col-12">
                                    <input type="radio" class="btn-check" asp-for="Goal" value="Lose Weight" id="goalWeight" />
                                    <label class="btn btn-outline-primary w-100 p-3 text-start rounded-3" for="goalWeight">
                                        <div class="d-flex align-items-center">
                                            <div class="icon-box bg-success-subtle text-success rounded-circle p-2 me-3">
                                                <i class="bi bi-lightning-charge fs-4"></i>
                                            </div>
                                            <div>
                                                <strong class="d-block text-dark">Lose Weight & Fat Loss</strong>
                                                <span class="text-muted small">High intensity circuits and conditioning for calorie burning</span>
                                            </div>
                                        </div>
                                    </label>
                                </div>

                                <div class="col-12">
                                    <input type="radio" class="btn-check" asp-for="Goal" value="Cardio Endurance" id="goalCardio" />
                                    <label class="btn btn-outline-primary w-100 p-3 text-start rounded-3" for="goalCardio">
                                        <div class="d-flex align-items-center">
                                            <div class="icon-box bg-info-subtle text-info rounded-circle p-2 me-3">
                                                <i class="bi bi-activity fs-4"></i>
                                            </div>
                                            <div>
                                                <strong class="d-block text-dark">Cardio & Athletic Endurance</strong>
                                                <span class="text-muted small">Improve heart health, stamina, and overall VO2 max</span>
                                            </div>
                                        </div>
                                    </label>
                                </div>
                            </div>
                            <span asp-validation-for="Goal" class="text-danger small"></span>
                        </div>

                        <!-- Frequency -->
                        <div class="mb-4">
                            <label asp-for="Frequency" class="form-label fw-bold text-dark mb-2">How many days per week can you train?</label>
                            <div class="d-flex gap-3 justify-content-between">
                                <div class="flex-fill">
                                    <input type="radio" class="btn-check" asp-for="Frequency" value="3" id="freq3" checked />
                                    <label class="btn btn-outline-secondary w-100 py-3 fw-bold rounded-3" for="freq3">3 Days</label>
                                </div>
                                <div class="flex-fill">
                                    <input type="radio" class="btn-check" asp-for="Frequency" value="4" id="freq4" />
                                    <label class="btn btn-outline-secondary w-100 py-3 fw-bold rounded-3" for="freq4">4 Days</label>
                                </div>
                                <div class="flex-fill">
                                    <input type="radio" class="btn-check" asp-for="Frequency" value="5" id="freq5" />
                                    <label class="btn btn-outline-secondary w-100 py-3 fw-bold rounded-3" for="freq5">5 Days</label>
                                </div>
                            </div>
                            <span asp-validation-for="Frequency" class="text-danger small"></span>
                        </div>

                        <!-- Experience Level -->
                        <div class="mb-4">
                            <label asp-for="ExperienceLevel" class="form-label fw-bold text-dark mb-2">What is your gym experience level?</label>
                            <select asp-for="ExperienceLevel" class="form-select form-select-lg rounded-3">
                                <option value="Beginner">Beginner (Just starting out / Less than 6 months)</option>
                                <option value="Intermediate">Intermediate (Consistent training / 6 to 24 months)</option>
                                <option value="Advanced">Advanced (Experienced lifter / Over 2 years)</option>
                            </select>
                            <span asp-validation-for="ExperienceLevel" class="text-danger small"></span>
                        </div>

                        <div class="mt-5">
                            <button type="submit" class="btn btn-primary w-100 py-3 fw-bold btn-lg rounded-3 border-0 shadow-sm" style="background: linear-gradient(135deg, #0a1172 0%, #2d3fdb 100%) !important;">
                                <i class="bi bi-magic me-2"></i>Generate Workout Plan
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            
            @if (ViewBag.HasActivePlan == true)
            {
                <div class="text-center mt-4">
                    <a asp-action="MyPlan" class="btn btn-link text-decoration-none fw-bold">
                        <i class="bi bi-arrow-left me-2"></i>Back to Active Plan
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .btn-check:checked + .btn-outline-primary {
        background-color: #f0f3ff;
        border-color: #2d3fdb;
    }
    .btn-outline-primary {
        border-color: #e2e8f0;
    }
    .btn-outline-primary:hover {
        background-color: #f8fafc;
        border-color: #cbd5e1;
    }
    .btn-check:checked + .btn-outline-secondary {
        background-color: #0a1172;
        border-color: #0a1172;
        color: white;
    }
    .btn-outline-secondary {
        border-color: #e2e8f0;
        color: #475569;
    }
    .btn-outline-secondary:hover {
        background-color: #f1f5f9;
        color: #1e293b;
    }
    .icon-box {
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>
