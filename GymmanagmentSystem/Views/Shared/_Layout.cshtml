<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GymmanagmentSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GymmanagmentSystem.styles.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/my-gym-icon.png?v=3" />

    <style>
            /* Responsive navbar fixes - keeps everything visible without breaking */
            .navbar-nav {
                flex-wrap: wrap;
                justify-content: center;
            }

                .navbar-nav .nav-link {
                    white-space: nowrap;
                    padding: 0.5rem 0.75rem !important;
                    font-size: 1rem;
                }

            /* On tablets and small laptops, shrink font and padding so all items fit */
            @@media (max-width: 1199.98px) {
                .navbar-nav .nav-link {
                    font-size: 0.85rem !important;
                    padding: 0.4rem 0.6rem !important;
                }

                .navbar-brand img {
                    max-height: 40px;
                }
            }

            /* On mobile, keep the collapsed menu as is */
            @@media (max-width: 991.98px) {
                .navbar-nav .nav-link {
                    font-size: 1rem !important;
                    padding: 0.6rem 1rem !important;
                    width: 100%;
                    text-align: center;
                }

                .navbar-nav {
                    flex-direction: column;
                    align-items: center;
                }
            }

            /* Prevent any overflow */
            .navbar {
                overflow: visible;
            }

            .navbar-collapse {
                max-height: 80vh;
                overflow-y: auto;
            }

            /* .container {
                max-width: 90%;
                padding-left: 15px;
                padding-right: 15px;
            } */
    </style>
</head>
<body>
    @inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

        string IsActive(params string[] controllers)
        {
            return controllers.Contains(currentController, StringComparer.OrdinalIgnoreCase) ? "active" : "";
        }

        // Load gym announcement from JSON file
        var announcementPath = System.IO.Path.Combine(Env.WebRootPath, "data", "announcement.json");
        GymMangment.BLL.ViewModels.AnnouncementViewModel? announcement = null;
        if (System.IO.File.Exists(announcementPath))
        {
            try
            {
                var json = System.IO.File.ReadAllText(announcementPath);
                announcement = System.Text.Json.JsonSerializer.Deserialize<GymMangment.BLL.ViewModels.AnnouncementViewModel>(json);
            }
            catch { }
        }
    }

    @if (announcement != null && announcement.IsActive && !string.IsNullOrEmpty(announcement.Message))
    {
        <div class="alert alert-@announcement.StyleClass alert-dismissible fade show rounded-0 mb-0 border-0 text-center py-3 position-relative" id="announcementBanner" role="alert" style="z-index: 1050; font-size: 1rem; font-weight: 500;">
            <div class="container d-flex align-items-center justify-content-center gap-2">
                <i class="bi bi-megaphone-fill fs-5"></i>
                <span>@announcement.Message</span>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="top: 50%; transform: translateY(-50%); right: 1.5rem;"></button>
        </div>
    }

    <header>
        <nav class="navbar navbar-expand-lg bg-white my-3">
            <div class="container">
                <a class="navbar-brand" href="#">
                    <img src="~/images/logo.jpg" alt="Logo" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav m-auto mb-2 mb-lg-0 mt-3 mt-lg-0">
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @IsActive("Home")" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @IsActive("Members")" asp-controller="Members" asp-action="Index">Members</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @IsActive("Trainers")" asp-controller="Trainers" asp-action="Index">Trainers</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @IsActive("Sessions")" asp-controller="Sessions" asp-action="Index">Sessions</a>
                            </li>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @IsActive("Plans")" asp-controller="Plans" asp-action="Index">Plans</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @IsActive("Memberships")" asp-controller="Memberships" asp-action="Index">Memberships</a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @IsActive("SessionsSchedule")" asp-controller="SessionsSchedule" asp-action="Index">Sessions Schedule</a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @IsActive("DeleteRequests")" asp-controller="DeleteRequests" asp-action="Index">Delete Requests</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @IsActive("Admin")" asp-controller="Admin" asp-action="Users">Users</a>
                            </li>
                        }

                        @if (User.IsInRole("Member"))
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @(currentController == "Members" && ViewContext.RouteData.Values["action"]?.ToString() == "MyProfile" ? "active" : "")"
                                   asp-controller="Members" asp-action="MyProfile">My Profile</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @(currentController == "Memberships" && ViewContext.RouteData.Values["action"]?.ToString() == "MyMembership" ? "active" : "")"
                                   asp-controller="Memberships" asp-action="MyMembership">My Membership</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @(currentController == "Bookings" && ViewContext.RouteData.Values["action"]?.ToString() == "MyBookings" ? "active" : "")"
                                   asp-controller="Bookings" asp-action="MyBookings">My Bookings</a>
                            </li>
                        }

                        <li class="nav-item">
                            <form asp-action="Logout" asp-controller="Account" method="post" class="d-inline">
                                <button type="submit" class="btn btn-link nav-link px-3 py-2 mx-2 fw-bolder fs-5 text-black-alternative" style="text-decoration: none;">
                                    Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["WarningMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                    @TempData["WarningMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        setTimeout(function () {
            document.querySelectorAll('.alert:not(#announcementBanner)').forEach(function (alertEl) {
                var bsAlert = bootstrap.Alert.getOrCreateInstance(alertEl);
                bsAlert.close();
            });
        }, 3000);
    </script>
</body>
</html>