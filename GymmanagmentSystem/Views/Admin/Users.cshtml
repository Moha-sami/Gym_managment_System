@using GymMangment.BLL.ViewModels.AccountViewModels
@model IEnumerable<UserViewModel>
@{
    ViewData["Title"] = "User Management";
}

<div class="container">
    <header class="d-flex justify-content-between mt-5 mb-4 align-items-center">
        <div>
            <h2 class="text-primary-color mb-0">User Management</h2>
            <p class="text-muted">Manage user accounts and assign roles</p>
        </div>
        <a asp-controller="Admin" asp-action="ManageAnnouncement" class="btn btn-outline fw-medium rounded-pill px-4 py-3">
            <i class="bi bi-megaphone me-2"></i>Announcement Board
        </a>
    </header>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-borderless">
                <thead>
                    <tr>
                        <th><span>Full Name</span></th>
                        <th><span>Email</span></th>
                        <th><span>Current Role</span></th>
                        <th><span>Assign Role</span></th>
                        <th><span>Action</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td><span class="fw-bold">@user.FullName</span></td>
                            <td><span>@user.Email</span></td>
                            <td>
                                @if (!string.IsNullOrEmpty(user.CurrentRole))
                                {
                                    <span class="badge bg-primary-color">@user.CurrentRole</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No Role</span>
                                }
                            </td>
                            <td>
                                <form asp-controller="Admin" asp-action="AssignRole" method="post" class="d-flex gap-2">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <select name="role" class="form-select form-select-sm" style="width: auto;">
                                        <option value="">-- No Role --</option>
                                        @foreach (var role in user.AvailableRoles)
                                        {
                                            <option value="@role" selected="@(role == user.CurrentRole)">@role</option>
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-fill btn-sm">
                                        <i class="bi bi-check-lg me-1"></i>Assign
                                    </button>
                                </form>
                            </td>
                            <td>
                                <form asp-controller="Admin" asp-action="DeleteUser" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this user?')">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-outline text-danger btn-sm">
                                        <i class="bi bi-trash me-1"></i>Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-people display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No Users Found</h4>
        </div>
    }
</div>
