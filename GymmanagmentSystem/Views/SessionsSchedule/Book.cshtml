@model GymMangment.BLL.ViewModels.BookingViewModels.CreateBookingViewModel
@{
    ViewData["Title"] = "Book Session";
}

<div class="container mt-4">
    <header class="mb-4">
        <h3 class="text-primary-color">Confirm Booking</h3>
        <p class="text-muted">You're about to book this session</p>
    </header>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-calendar-check display-4 text-primary-color mb-3"></i>
                    <p class="mb-4">Click confirm below to book your spot in this session.</p>

                    <form asp-controller="SessionsSchedule" asp-action="Book" method="post">
                        <input type="hidden" asp-for="SessionId" />
                        <input type="hidden" asp-for="MemberId" />

                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a asp-controller="SessionsSchedule" asp-action="Index" class="btn btn-outline">
                                <i class="bi bi-arrow-left me-1"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-fill">
                                <i class="bi bi-check-lg me-1"></i>Confirm Booking
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
