@model GymMangment.BLL.ViewModels.AnalyticsViewModels.MemberAnalyticsViewModel
@{
    ViewData["Title"] = "My Analytics";
}

<style>
    .analytics-banner {
        background: linear-gradient(135deg, rgba(124,58,237,0.2), rgba(219,39,119,0.15), rgba(0,240,255,0.1));
        border: 1px solid rgba(255,255,255,0.1);
        backdrop-filter: blur(20px);
        border-radius: 28px;
        padding: 40px;
    }
    .chart-glass-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(16px);
        border-radius: 24px;
        height: 100%;
        overflow: hidden;
    }
    .chart-header {
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
        padding: 20px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }
    .chart-header h3 {
        font-size: 1.05rem;
        font-weight: 700;
        color: #ffffff;
        margin: 0;
    }
    .glass-select-sm {
        background-color: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.12) !important;
        color: #ffffff !important;
        border-radius: 20px !important;
        padding: 4px 12px !important;
        font-size: 0.82rem !important;
    }
    .glass-select-sm option {
        background: #0f0c1e !important;
        color: #ffffff !important;
    }
    @@media (max-width: 768px) {
        .analytics-banner {
            padding: 24px 16px !important;
            border-radius: 20px !important;
        }
        .chart-glass-card {
            border-radius: 20px !important;
        }
        .chart-header {
            padding: 16px 20px !important;
        }
        .chart-glass-card .p-4 {
            padding: 16px 12px !important;
        }
    }
</style>

<div class="container py-4 text-white">
    <!-- Header Card -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="analytics-banner">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-4">
                    <div>
                        <span class="badge bg-purple text-white mb-2 px-3 py-1.5 fs-6 fw-bold rounded-pill" style="background:linear-gradient(135deg,#7c3aed,#db2777);">📊 Data &amp; Metrics</span>
                        <h1 class="display-5 fw-extrabold text-white mb-1">Fitness Analytics</h1>
                        <p class="fs-6 text-white-50 mb-3" style="max-width:600px;">Track your weight progress, workout volume, training consistency, and 1RM trends in real time.</p>
                        <div class="d-flex gap-2 header-buttons-wrap">
                            <a asp-controller="Members" asp-action="MyProfile" class="btn-glow-pill">
                                <i class="bi bi-person-fill me-1"></i>My Profile
                            </a>
                            <a asp-controller="Memberships" asp-action="MyMembership" class="btn-glow-pill">
                                <i class="bi bi-card-checklist me-1"></i>My Membership
                            </a>
                        </div>
                    </div>
                    <div>
                        <label class="form-label fw-bold text-white-50 small text-uppercase" style="letter-spacing:1px;font-size:0.7rem;">Time Frame</label>
                        <select id="timeframeSelect" class="form-select glass-select-sm" style="min-width: 180px; padding: 10px 16px !important; cursor: pointer;">
                            <option value="30">Last 30 Days</option>
                            <option value="90">Last 90 Days</option>
                            <option value="180" selected>Last 6 Months</option>
                            <option value="365">Last Year</option>
                            <option value="3650">All Time</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Analytics Charts Grid -->
    <div class="row g-4">
        <!-- 1. Weight Progress Chart -->
        <div class="col-md-6">
            <div class="chart-glass-card">
                <div class="chart-header">
                    <h3><i class="bi bi-activity text-neon me-2"></i>Weight Tracker</h3>
                    <span id="currentWeightBadge" class="badge rounded-pill px-3 py-1.5 font-monospace" style="background:rgba(0,240,255,0.15);color:#00f0ff;border:1px solid rgba(0,240,255,0.3);">-- kg</span>
                </div>
                <div class="p-4 d-flex align-items-center justify-content-center" style="position: relative; height: 320px;">
                    <canvas id="weightChart"></canvas>
                    <div id="weightNoData" class="text-center text-white-50 d-none">
                        <i class="bi bi-calendar-x display-4 mb-2 d-block opacity-50"></i>
                        <span>No weight logs recorded in this period.</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. Workout Consistency -->
        <div class="col-md-6">
            <div class="chart-glass-card">
                <div class="chart-header">
                    <h3><i class="bi bi-calendar-check text-success me-2"></i>Workout Consistency</h3>
                    <span id="totalWorkoutsBadge" class="badge rounded-pill px-3 py-1.5" style="background:rgba(34,197,94,0.15);color:#4ade80;border:1px solid rgba(34,197,94,0.3);">-- Workouts</span>
                </div>
                <div class="p-4 d-flex align-items-center justify-content-center" style="position: relative; height: 320px;">
                    <canvas id="frequencyChart"></canvas>
                    <div id="frequencyNoData" class="text-center text-white-50 d-none">
                        <i class="bi bi-calendar-x display-4 mb-2 d-block opacity-50"></i>
                        <span>No workouts logged in this period.</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- 3. Training Volume -->
        <div class="col-md-6">
            <div class="chart-glass-card">
                <div class="chart-header">
                    <h3><i class="bi bi-lightning-charge-fill text-warning me-2"></i>Training Volume</h3>
                    <span id="avgVolumeBadge" class="badge rounded-pill px-3 py-1.5 font-monospace" style="background:rgba(255,193,7,0.15);color:#ffc107;border:1px solid rgba(255,193,7,0.3);">-- kg avg</span>
                </div>
                <div class="p-4 d-flex align-items-center justify-content-center" style="position: relative; height: 320px;">
                    <canvas id="volumeChart"></canvas>
                    <div id="volumeNoData" class="text-center text-white-50 d-none">
                        <i class="bi bi-calendar-x display-4 mb-2 d-block opacity-50"></i>
                        <span>No volume data available.</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- 4. Max Weight / 1RM Trend -->
        <div class="col-md-6">
            <div class="chart-glass-card">
                <div class="chart-header flex-wrap gap-2">
                    <h3><i class="bi bi-graph-up-arrow text-danger me-2"></i>Strength / 1RM Trend</h3>
                    <div style="min-width: 160px;">
                        <select id="exerciseSelect" class="form-select glass-select-sm">
                            @if (Model.LoggedExercises.Any())
                            {
                                @foreach (var exercise in Model.LoggedExercises)
                                {
                                    <option value="@exercise">@exercise</option>
                                }
                            }
                            else
                            {
                                <option value="">-- No Exercises Logged --</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="p-4 d-flex align-items-center justify-content-center" style="position: relative; height: 320px;">
                    <canvas id="exerciseChart"></canvas>
                    <div id="exerciseNoData" class="text-center text-white-50 d-none">
                        <i class="bi bi-calendar-x display-4 mb-2 d-block opacity-50"></i>
                        <span>Log sets for this exercise to generate progress trends.</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Include Chart.js via CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const memberId = @Model.MemberId;
        let weightChart, frequencyChart, volumeChart, exerciseChart;

        // Set Chart.js Defaults for Dark Glass Theme
        Chart.defaults.color = 'rgba(255, 255, 255, 0.6)';
        Chart.defaults.font.family = "'Inter', sans-serif";

        const colors = {
            primary: '#00f0ff',
            primaryBg: 'rgba(0, 240, 255, 0.15)',
            success: '#4ade80',
            successBg: 'rgba(74, 222, 128, 0.15)',
            warning: '#ffc107',
            warningBg: 'rgba(255, 193, 7, 0.15)',
            danger: '#f472b6',
            dangerBg: 'rgba(244, 114, 182, 0.15)'
        };

        const gridOptions = {
            color: 'rgba(255, 255, 255, 0.05)',
            borderColor: 'rgba(255, 255, 255, 0.1)'
        };

        // Initialize and load all chart data
        async function loadDashboardData() {
            const days = document.getElementById('timeframeSelect').value;
            
            try {
                const response = await fetch(`/Analytics/GetChartData?memberId=${memberId}&days=${days}`);
                if (!response.ok) throw new Error("Failed to fetch analytics");
                const data = await response.json();

                renderWeightChart(data.weightRecords);
                renderFrequencyChart(data.workoutFrequency);
                renderVolumeChart(data.workoutVolume);
                
                // Load exercise chart
                loadExerciseData();
            } catch (err) {
                console.error(err);
            }
        }

        async function loadExerciseData() {
            const days = document.getElementById('timeframeSelect').value;
            const exerciseSelect = document.getElementById('exerciseSelect');
            const exerciseName = exerciseSelect.value;

            if (!exerciseName) {
                toggleNoDataPlaceholder('exerciseChart', 'exerciseNoData', true);
                return;
            }

            try {
                const response = await fetch(`/Analytics/GetExerciseData?memberId=${memberId}&exerciseName=${encodeURIComponent(exerciseName)}&days=${days}`);
                if (!response.ok) throw new Error("Failed to fetch exercise trends");
                const data = await response.json();
                
                renderExerciseChart(data);
            } catch (err) {
                console.error(err);
            }
        }

        function toggleNoDataPlaceholder(canvasId, placeholderId, show) {
            const canvas = document.getElementById(canvasId);
            const placeholder = document.getElementById(placeholderId);
            if (show) {
                canvas.classList.add('d-none');
                placeholder.classList.remove('d-none');
            } else {
                canvas.classList.remove('d-none');
                placeholder.classList.add('d-none');
            }
        }

        // Render functions
        function renderWeightChart(records) {
            if (weightChart) weightChart.destroy();
            
            const hasData = records && records.length > 0;
            toggleNoDataPlaceholder('weightChart', 'weightNoData', !hasData);

            if (!hasData) {
                document.getElementById('currentWeightBadge').innerText = '-- kg';
                return;
            }

            const latestWeight = records[records.length - 1].weight;
            document.getElementById('currentWeightBadge').innerText = `${latestWeight} kg`;

            const ctx = document.getElementById('weightChart').getContext('2d');
            weightChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: records.map(r => r.dateLabel),
                    datasets: [{
                        label: 'Weight (kg)',
                        data: records.map(r => r.weight),
                        borderColor: colors.primary,
                        backgroundColor: colors.primaryBg,
                        borderWidth: 3,
                        fill: true,
                        tension: 0.3,
                        pointRadius: 4,
                        pointHoverRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: false, grid: gridOptions },
                        x: { grid: { display: false } }
                    }
                }
            });
        }

        function renderFrequencyChart(records) {
            if (frequencyChart) frequencyChart.destroy();

            const hasData = records && records.length > 0;
            toggleNoDataPlaceholder('frequencyChart', 'frequencyNoData', !hasData);

            if (!hasData) {
                document.getElementById('totalWorkoutsBadge').innerText = '-- Workouts';
                return;
            }

            const total = records.reduce((sum, r) => sum + r.workoutCount, 0);
            document.getElementById('totalWorkoutsBadge').innerText = `${total} Workouts`;

            const ctx = document.getElementById('frequencyChart').getContext('2d');
            frequencyChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: records.map(r => r.dateLabel),
                    datasets: [{
                        label: 'Workouts',
                        data: records.map(r => r.workoutCount),
                        backgroundColor: colors.success,
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: gridOptions },
                        x: { grid: { display: false } }
                    }
                }
            });
        }

        function renderVolumeChart(records) {
            if (volumeChart) volumeChart.destroy();

            const hasData = records && records.length > 0;
            toggleNoDataPlaceholder('volumeChart', 'volumeNoData', !hasData);

            if (!hasData) {
                document.getElementById('avgVolumeBadge').innerText = '-- kg avg';
                return;
            }

            const totalVol = records.reduce((sum, r) => sum + r.totalVolume, 0);
            const avgVol = Math.round(totalVol / records.length);
            document.getElementById('avgVolumeBadge').innerText = `${avgVol.toLocaleString()} kg avg`;

            const ctx = document.getElementById('volumeChart').getContext('2d');
            volumeChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: records.map(r => r.dateLabel),
                    datasets: [{
                        label: 'Total Volume (kg)',
                        data: records.map(r => r.totalVolume),
                        backgroundColor: colors.warning,
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: gridOptions },
                        x: { grid: { display: false } }
                    }
                }
            });
        }

        function renderExerciseChart(records) {
            if (exerciseChart) exerciseChart.destroy();

            const hasData = records && records.length > 0;
            toggleNoDataPlaceholder('exerciseChart', 'exerciseNoData', !hasData);

            if (!hasData) return;

            const ctx = document.getElementById('exerciseChart').getContext('2d');
            exerciseChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: records.map(r => r.dateLabel),
                    datasets: [{
                        label: 'Est. 1RM (kg)',
                        data: records.map(r => r.oneRepMax),
                        borderColor: colors.danger,
                        backgroundColor: colors.dangerBg,
                        borderWidth: 3,
                        fill: true,
                        tension: 0.3,
                        pointRadius: 4,
                        pointHoverRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: false, grid: gridOptions },
                        x: { grid: { display: false } }
                    }
                }
            });
        }

        // Event Listeners
        document.getElementById('timeframeSelect').addEventListener('change', loadDashboardData);
        document.getElementById('exerciseSelect').addEventListener('change', loadExerciseData);

        // Initial Load
        document.addEventListener('DOMContentLoaded', loadDashboardData);
    </script>
}
