{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",


  "ConnectionStrings": {
    
  "DefaultConnection": "Server=.;Database=GymDb;Trusted_Connection=True;TrustServerCertificate=True;",
  },
  "SmtpSettings": {
    "Host": "smtp-relay.brevo.com",
    "Port": 587,
    "Username": "YOUR_BREVO_LOGIN_EMAIL",
    "Password": "YOUR_BREVO_SMTP_KEY",
    "SenderEmail": "YOUR_VERIFIED_SENDER_EMAIL",
    "EnableSsl": true,
    "SenderName": "Power Fitness"
  }
}
